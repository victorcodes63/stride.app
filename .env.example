# Database – PostgreSQL (required for ATS)
# Recommended: Neon (neon.tech) or Vercel Postgres – free tier for dev/preview, low cost + minimal maintenance for production.
# Neon URL example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Leave unset to use in-memory fallback (dev only; data is lost on restart).
DATABASE_URL="postgresql://user:password@localhost:5432/eagle_hr_ats?schema=public"

# SMTP – for contact form and applicant emails (application received, status update)
SMTP_HOST="mail.eaglehr.co.ke"
SMTP_PORT="465"
SMTP_USER="info@eaglehr.co.ke"
SMTP_PASS="your_email_password"

# Staff dashboard auth – required in production for /dashboard
# In development, if unset, you can sign in with password "eaglehr" (any email)
STAFF_PASSWORD="your_secure_password"
# Optional: restrict login to one email (leave unset to allow any email)
# STAFF_EMAIL="staff@eaglehr.co.ke"

# Optional – ATS external API (if you use an external ATS later)
# NEXT_PUBLIC_ATS_API_URL=
# NEXT_PUBLIC_ATS_API_KEY=
