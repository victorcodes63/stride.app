# Database – PostgreSQL (required for ATS)
# Recommended: Neon (neon.tech) or Vercel Postgres – free tier for dev/preview, low cost + minimal maintenance for production.
# Neon URL example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Leave unset to use in-memory fallback (dev only; data is lost on restart).
DATABASE_URL="postgresql://user:password@localhost:5432/hris_demo?schema=public"

# —— Deployment mode ——
# Production client instances: leave DEMO_MODE unset or false.
# Internal sales/demo instance only:
# DEMO_MODE=true
# DEMO_PACK=generic
# DEMO_PACK=petroleum-retail

# —— Demo login hints (sales instances only; must match seeded demo accounts) ——
# NEXT_PUBLIC_DEMO_PASSWORD="Demo@2026!"
# NEXT_PUBLIC_DEMO_ADMIN_EMAIL="demo@example.com"
# NEXT_PUBLIC_DEMO_HR_EMAIL="hr.demo@example.com"
# NEXT_PUBLIC_DEMO_FINANCE_EMAIL="finance.demo@example.com"
# NEXT_PUBLIC_DEMO_ESS_EMAIL="employee.demo@example.com"
# MFA TOTP issuer label (defaults to NEXT_PUBLIC_APP_NAME)
# NEXT_PUBLIC_BRAND_NAME="HRIS Demo"

# —— Client provisioning (production seed: npm run seed:production) ——
# PROVISION_ORG_NAME="Acme Limited"
# PROVISION_EMPLOYEE_PREFIX="ACM"
# PROVISION_CURRENCY="KES"
# DEFAULT_COUNTRY="KE"
# MULTI_ENTITY_ENABLED=false
# When MULTI_ENTITY_ENABLED=true at provision, seed can create multiple OutsourcingClient rows (ke + ug).
# PROVISION_CONTACT_NAME="HR Department"
# PROVISION_CONTACT_EMAIL="hr@acme.co.ke"
# PROVISION_CONTACT_PHONE="+254 700 000 000"
# PROVISION_ADMIN_EMAIL="hr.admin@acme.co.ke"
# PROVISION_ADMIN_NAME="System Administrator"
# PROVISION_ADMIN_PASSWORD="generate_a_strong_password"

# —— Module licensing (all default to enabled; set false to disable on this deployment) ——
# MODULE_LEAVE=false
# MODULE_TIME=false
# MODULE_PAYROLL=false
# MODULE_ATS=false
# MODULE_PERFORMANCE=false
# MODULE_HSE=false
# MODULE_ACCOUNTS=false
# MODULE_DISCIPLINARY=false
# MODULE_REPORTS=false
# MODULE_ASSETS=false
# MODULE_ESS=false

# —— Public branding (required for production client deployments) ——
# NEXT_PUBLIC_APP_NAME="Acme HRIS"
# NEXT_PUBLIC_ORG_NAME="Acme Limited"
# Legacy: hide demo login hints (prefer DEMO_MODE=false instead)
# NEXT_PUBLIC_SHOW_DEMO_LOGIN_HINT=false
# NEXT_PUBLIC_APP_TAGLINE="Human resources, payroll, recruitment, and workforce operations in one place."
# NEXT_PUBLIC_CONTACT_EMAIL="hello@example.com"
# NEXT_PUBLIC_CONTACT_PHONE="+1 (555) 010-0200"
# NEXT_PUBLIC_CONTACT_ADDRESS="100 Demo Plaza, Suite 900"
# Logo paths under /public (SVG for UI; PNG for email/PDF inline images)
# NEXT_PUBLIC_BRAND_LOGO="/brand/platform-logo.png"
# NEXT_PUBLIC_BRAND_LOGO_PNG="/brand/platform-logo.png"
# NEXT_PUBLIC_BRAND_WORDMARK="ACME HRIS"

# Recruitment (single employer / ATS) — default public employer name when `RecruitmentSettings` is not loaded yet (e.g. in-memory dev).
# Production: prefer editing Dashboard → Recruitment → Organization (stores row id `default` + optional `linkedClientId` for Accounts).
# NEXT_PUBLIC_RECRUITMENT_EMPLOYER_NAME="Acme Limited"
# RECRUITMENT_EMPLOYER_NAME="Acme Limited"

# Neon on Vercel: use the pooled URL above for runtime (DATABASE_URL). For builds, set a second env var with
# the direct (non-pooling) host so `prisma migrate deploy` can take advisory locks (avoids P1002 on *-pooler* hosts).
# In Neon dashboard: same database → copy "connection string" for the direct endpoint (no "-pooler" in hostname).
# DIRECT_DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Vercel Production runs `prisma migrate deploy` automatically during `npm run build` (see scripts/prisma-migrate-deploy.js).
# Set RUN_MIGRATIONS_ON_BUILD=false only if you must skip migrations on Production (not recommended).
# Preview builds do not auto-migrate; point Preview DATABASE_URL at a dev Neon branch if you need migrations there.
# For local `npm run build`, set RUN_MIGRATIONS_ON_BUILD=true if you want migrate deploy locally.
# RUN_MIGRATIONS_ON_BUILD=true

# SMTP – contact form + applicant emails (application received, status updates, etc.)
# Use recruitment@example.com so applicants see a consistent sender.
#
# Option A – Microsoft 365 (recommended if you use Outlook/Office 365):
# SMTP_HOST="smtp.office365.com"
# SMTP_PORT="587"
# SMTP_USER="recruitment@example.com"
# SMTP_PASS="your_app_password"
# (Create an app password in Microsoft 365: Account → Security → App passwords.)
#
# Option B – Your own mail server (e.g. mail.example.com):
# SMTP_HOST="mail.example.com"
# SMTP_PORT="465"
# SMTP_USER="recruitment@example.com"
# SMTP_PASS="your_email_password"
#
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="recruitment@example.com"
SMTP_PASS=""
# Optional explicit "From" email (fallback chain uses SMTP_USER)
# SMTP_FROM_EMAIL="recruitment@example.com"
# Display name shown as sender (e.g. "HRIS Demo HR"). If unset, defaults to "<NEXT_PUBLIC_APP_NAME or HRIS Demo> HR".
# Set this in production (e.g. Vercel env) so the From name is correct; otherwise some hosts may show only "recruitment".
# SMTP_FROM_NAME="HRIS Demo HR"

# Optional dedicated Accounts SMTP credentials (falls back to SMTP_* when unset)
# ACCOUNTS_SMTP_HOST="smtp.office365.com"
# ACCOUNTS_SMTP_PORT="587"
# ACCOUNTS_SMTP_USER="accounts@example.com"
# ACCOUNTS_SMTP_PASS="your_accounts_app_password"
# ACCOUNTS_SMTP_FROM_NAME="HRIS Demo HR (Accounts)"
# Optional: full URL of your live site (for logo in emails, OAuth, and SEO canonical/OG URLs). Defaults to https://www.example.com or Vercel URL.
# NEXT_PUBLIC_SITE_URL="https://www.example.com"

# Optional: Google Search Console verification (meta tag content only, no full HTML). Get it from Search Console → Settings → Ownership verification.
# GOOGLE_SITE_VERIFICATION="your-verification-code"

# Staff dashboard auth – required in production for /dashboard
# In development, if unset, default dev password matches prisma seed scripts (e.g. Demo@2026!)
STAFF_PASSWORD="your_secure_password"
# Restrict staff sign-in to this email domain (applies to password, Microsoft, and Google sign-in)
# Comma-separated. Must include domains used by seeded demo or production admin accounts.
STAFF_ALLOWED_DOMAIN="example.com"
# Optional: staff session duration in days (rolling refresh on activity)
# STAFF_SESSION_DAYS="7"
# Optional: restrict login to one email (leave unset to allow any email)
# STAFF_EMAIL="staff@example.com"

# Optional ESS OAuth redirect overrides (defaults to /api/ess/auth/{provider}/callback)
# ESS_MS_REDIRECT_URI="http://localhost:3000/api/ess/auth/microsoft/callback"
# ESS_GOOGLE_REDIRECT_URI="http://localhost:3000/api/ess/auth/google/callback"
# Optional: restrict ESS OAuth to specific domains (defaults to STAFF_ALLOWED_DOMAIN)
# ESS_ALLOWED_DOMAIN="company.co.ke"
# Create an app registration in Entra ID and add redirect URIs:
# http://localhost:3000/api/auth/microsoft/callback (staff)
# http://localhost:3000/api/ess/auth/microsoft/callback (ESS)
# https://your-domain/api/auth/microsoft/callback (prod staff)
# https://your-domain/api/ess/auth/microsoft/callback (prod ESS)
# MS_TENANT_ID="your-tenant-id"
# MS_CLIENT_ID="your-app-client-id"
# MS_CLIENT_SECRET="your-app-client-secret"
# Optional if you want to override callback URL directly:
# MS_REDIRECT_URI="http://localhost:3000/api/auth/microsoft/callback"
# Optional: set true only when troubleshooting OAuth
# MS_OAUTH_DEBUG="false"
#
# Google OAuth (optional, for "Sign in with Google" on staff login)
# In Google Cloud Console: APIs & Services → Credentials → OAuth 2.0 Client ID (Web).
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/google/callback (staff)
#   http://localhost:3000/api/ess/auth/google/callback (ESS)
#   https://your-domain/api/auth/google/callback
#   https://your-domain/api/ess/auth/google/callback
# GOOGLE_CLIENT_ID="your-oauth-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-oauth-client-secret"
# Optional if you want to override the callback URL directly:
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
# Optional: set true only when troubleshooting OAuth
# GOOGLE_OAUTH_DEBUG="false"
#
# Microsoft Graph Mail (recommended on Vercel, avoids SMTP timeout issues)
# In Entra app registration -> API permissions:
# - Add APPLICATION permission: Mail.Send
# - Click "Grant admin consent"
# Mail is sent through this mailbox:
# MS_GRAPH_MAILBOX="recruitment@example.com"

# Optional monitoring webhook for API failure alerts (Slack/Teams/webhook receiver)
# MONITORING_WEBHOOK_URL="https://hooks.slack.com/services/xxx/yyy/zzz"

# Daily contract reminders cron — `GET /api/cron/contract-reminders` (Vercel Cron sends Authorization: Bearer …).
# Must match the secret configured in the Vercel project (CRON_SECRET).
# CRON_SECRET="generate_a_long_random_string"

# Biometric poll cron — `GET /api/cron/biometric-poll` throttles via SchedulerLock: minimum seconds between successful runs.
# BIOMETRIC_POLL_INTERVAL_SECONDS="60"
# When set to 1/true, Hikvision ISAPI adapter skips HTTP (probe OK; poll returns no rows). Use for CI or local without hardware.
# HIKVISION_ISAPI_MOCK="1"

# Optional smoke test vars (used by npm run smoke:test and smoke:platform)
# SMOKE_BASE_URL="http://localhost:3000"
# SMOKE_LOGIN_EMAIL="admin@client.co.ke"
# SMOKE_LOGIN_PASSWORD="your-secure-password"
# SMOKE_APPLICATION_EMAIL="vichumo38+smoke@gmail.com"

# Vercel Blob – required in production for CV and document uploads
# On Vercel: Project → Storage → Create Blob store; BLOB_READ_WRITE_TOKEN is set automatically.
# Without it, resume/certificate uploads fail in production (read-only filesystem).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx..."

# Interview invite confirmation links – token signing secret (optional; falls back to DATABASE_URL if unset)
# Use a random string in production so confirmation/reschedule links cannot be forged.
# INTERVIEW_CONFIRM_SECRET="your-random-secret-at-least-32-chars"
# When running locally (npm run dev), invite links use localhost:3000 automatically.
# Override with INVITE_LINK_BASE to force a different URL (e.g. ngrok for mobile testing).
# INVITE_LINK_BASE="http://localhost:3000"

# Optional – full dev seed (npm run db:seed-full-dev): 5 clients, 30 jobs, 100 applicants
# Use a CV path you uploaded (e.g. from Vercel Blob or /uploads/resumes/...) so all applicants share it.
# SEED_CV_PATH="https://xxx.blob.vercel-storage.com/resumes/your-cv.pdf"
# SEED_DOC_PATH="https://xxx.blob.vercel-storage.com/documents/sample-cert.pdf"

# Optional – ATS external API (if you use an external ATS later)
# NEXT_PUBLIC_ATS_API_URL=
# NEXT_PUBLIC_ATS_API_KEY=
# NEXT_PUBLIC_ENABLE_ATS="false"
# NEXT_PUBLIC_DEBUG_ATS="false"

# Optional analytics
# GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"

# Optional – Accounts invoice PDF bank details (defaults: demo tenant name / Equity payroll vs consultancy accounts)
# HRIS_BANK_ACCOUNT_NAME="Your Company Limited"
# HRIS_BANK_NAME="Equity Bank"
# HRIS_BANK_CODE="068"
# HRIS_BRANCH_CODE="140"
# HRIS_BANK_SWIFT="EQBLKENYA"
# HRIS_BANK_PAYROLL_ACCOUNT="1400274191489"
# HRIS_BANK_CONSULTANCY_ACCOUNT="1400284455199"
# Optional: contact form destination (default info@example.com)
# CONTACT_FORM_TO="info@example.com"

# Runtime/platform-provided vars (normally DO NOT set manually)
# NODE_ENV="development"
# VERCEL_URL="your-project.vercel.app"
# TZ="Africa/Nairobi"
