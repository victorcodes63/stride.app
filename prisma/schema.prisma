  vendorId  String
  paidAt    DateTime @db.Date
  amount    Decimal  @db.Decimal(14, 2)
  reference String?
  method    String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor      AccountsVendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  allocations AccountsVendorPaymentAllocation[]

