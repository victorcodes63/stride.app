  reminders CredentialReminderSent[]

  @@index([employeeId, category])
  @@index([expiryDate])
  @@index([status])
}

enum CredentialReminderKind {
  days_30
  days_14
  days_7
  overdue
}

model CredentialReminderSent {
  id           String                 @id @default(cuid())
  credentialId String
  userId       String
  kind         CredentialReminderKind
  sentOnYmd    String
  createdAt    DateTime               @default(now())

  credential EmployeeCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([credentialId, userId, kind, sentOnYmd])
  @@index([sentOnYmd])
  @@index([kind])
}

// Payroll records (Kenyan jurisdiction: PAYE, NSSF, NHIF)
model Payroll {
  id          String   @id @default(cuid())
  employeeId  String
  month       Int      // 1-12
  year        Int
  basicPay    Decimal  @db.Decimal(12, 2)
  /// Bi-weekly: gross earned in 1st half of month (before monthly statutory combine)
  period1Gross Decimal? @db.Decimal(12, 2)
  period2Gross Decimal? @db.Decimal(12, 2)
  /// Bi-weekly: days present Mon–Sat per period. { period1: ["YYYY-MM-DD",...], period2: [...] }
  biweeklyAttendance Json?
  allowances  Json     @default("[]") // [{ name, amount }]
  deductions  Json     @default("[]") // [{ name, amount }]
  grossPay    Decimal  @db.Decimal(12, 2)
  leavePay    Decimal  @default(0) @db.Decimal(12, 2)
  paye        Decimal  @db.Decimal(12, 2) // PAYE tax
  nssf        Decimal  @db.Decimal(12, 2)
  nhif        Decimal  @db.Decimal(12, 2) // SHIF (2.75% gross)
  ahl         Decimal  @db.Decimal(12, 2) // Affordable Housing Levy 1.5% gross; pre-PAYE deduction
  /// NITA employer levy (flat per employee per month); not deducted from employee net pay.
  nita        Decimal  @default(0) @db.Decimal(12, 2)
  netPay      Decimal  @db.Decimal(12, 2)
  status      PayrollStatus @default(draft)
  /// Optional link to Accounts billing profile when one exists for the employee's outsourcing client.
  accountsClientId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  accountsClient AccountsClient? @relation(fields: [accountsClientId], references: [id], onDelete: SetNull)

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([year, month])
  @@index([accountsClientId])
}

enum PayrollStatus {
  draft
  approved
  paid
}

enum StatutoryReturnStatus {
  draft
  review_ready
  filed
  paid
  overdue
}

enum StatutoryObligationType {
  paye
  nssf
  shif
  housing_levy
}

enum StatutoryItemStatus {
  pending
  prepared
  submitted
  paid
  overdue
}

/// Monthly compliance return per outsourcing client with audit-friendly statutory totals.
model StatutoryReturn {
  id                   String                @id @default(cuid())
  outsourcingClientId  String
  month                Int
  year                 Int
  currency             String                @default("KES")
  employeeCount        Int                   @default(0)
  payrollCount         Int                   @default(0)
  totalGrossPay        Decimal               @default(0) @db.Decimal(14, 2)
  totalPaye            Decimal               @default(0) @db.Decimal(14, 2)
  totalNssfEmployee    Decimal               @default(0) @db.Decimal(14, 2)
  totalNssfEmployer    Decimal               @default(0) @db.Decimal(14, 2)
  totalShif            Decimal               @default(0) @db.Decimal(14, 2)
  totalAhlEmployee     Decimal               @default(0) @db.Decimal(14, 2)
  totalAhlEmployer     Decimal               @default(0) @db.Decimal(14, 2)
  totalOtherDeductions Decimal               @default(0) @db.Decimal(14, 2)
  status               StatutoryReturnStatus @default(draft)
  submittedAt          DateTime?
  paidAt               DateTime?
  notes                String?               @db.Text
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  client OutsourcingClient     @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  items  StatutoryReturnItem[]

  @@unique([outsourcingClientId, month, year])
  @@index([year, month])
  @@index([status])
}

/// One line per statutory obligation (PAYE/NSSF/SHIF/AHL) for filing and payment workflow.
model StatutoryReturnItem {
  id                String                  @id @default(cuid())
  statutoryReturnId String
  obligationType    StatutoryObligationType
  authority         String
  employeeAmount    Decimal                 @default(0) @db.Decimal(14, 2)
  employerAmount    Decimal                 @default(0) @db.Decimal(14, 2)
  liabilityAmount   Decimal                 @default(0) @db.Decimal(14, 2)
  dueDate           DateTime                @db.Date
  status            StatutoryItemStatus     @default(pending)
  referenceNumber   String?
  paymentReference  String?
  submittedAt       DateTime?
  paidAt            DateTime?
  notes             String?                 @db.Text
  metadata          Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  statutoryReturn StatutoryReturn @relation(fields: [statutoryReturnId], references: [id], onDelete: Cascade)

  @@unique([statutoryReturnId, obligationType])
  @@index([dueDate])
  @@index([status])
}

// Leave types (Annual, Sick, Maternity, etc.)
model LeaveType {
  id          String   @id @default(cuid())
  name        String   // e.g. Annual, Sick, Maternity, Paternity, Compassionate
  daysPerYear Int      @default(21) // default annual entitlement for Kenyan employment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leaveBalances      LeaveBalance[]
  leaveApplications  LeaveApplication[]
  leavePolicyRules   LeavePolicyRule[]
  leaveBalanceLedgers LeaveBalanceLedger[]
}

// Leave balance per employee per type per year
model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  year        Int
  balance     Int      @default(0) // days remaining
  used        Int      @default(0) // days used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType  LeaveType  @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
}

// Leave applications
model LeaveApplication {
  id          String        @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  days        Int
  status      LeaveStatus   @default(pending)
  reason      String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

enum LeaveStatus {
  pending
  approved
  rejected
}

// --- Biometric time terminals (M1) — device config is mutable; punches are append-only (no in-place updates).

/// Registered biometric device / time terminal (per outsourcing client).
model BiometricDevice {
  id                    String   @id @default(cuid())
  outsourcingClientId  String
  name                  String
  /// e.g. hikvision_isapi
  adapterKind          String
  /// Non-secret config (e.g. host). Secrets should stay in env / secret manager; references only here.
  config                Json?
  /// Last successful ISAPI poll instant (watermark for next `AcsEvent` time window).
  lastPollAt            DateTime?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  client OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  punches BiometricPunch[]

  @@index([outsourcingClientId])
  @@index([isActive])
  @@index([lastPollAt])
}

enum BiometricPunchSource {
  device
  csv
}

enum BiometricPunchDirection {
  in
  out
  unknown
}

/// Raw punch line from a device or CSV import — append-only; corrections are new rows.
model BiometricPunch {
  id                  String                   @id @default(cuid())
  biometricDeviceId  String
  /// Stable id for deduplication: vendor event id, or generated key for CSV rows.
  externalEventId    String
  observedAt         DateTime
  rawSubjectId      String
  /// Set when the subject maps cleanly to an employee; optional during ingestion.
  employeeId         String?
  rawPayload         Json?
  source            BiometricPunchSource
  direction         BiometricPunchDirection     @default(unknown)
  createdAt         DateTime                 @default(now())

  device   BiometricDevice @relation(fields: [biometricDeviceId], references: [id], onDelete: Cascade)
  employee Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  attendanceEvents AttendanceEvent[]

  @@unique([biometricDeviceId, externalEventId])
  @@index([biometricDeviceId, observedAt])
  @@index([employeeId])
}

// Attendance records (check-in/check-out)
model Attendance {
  id        String   @id @default(cuid())
  employeeId String
  date      DateTime @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

// Jobs can be synced from external ATS or managed in-app; id can match external system
model Job {
  id                String   @id @default(cuid())
  referenceId       String?  @unique // human-readable e.g. JOB-2026-0001; generated on create
  slug              String?  @unique // URL-safe e.g. senior-accountant-nairobi; used for /careers/apply/[slug]
  title             String
  company           String   // display name: client name or "Confidential" when client.isAnonymous
  location          String
  type              String   // Full Time | Part Time | Contract | Remote
  category          String
  postedDate        DateTime @default(now())
  description       String   @db.Text
  requirements      Json     // string[]
  responsibilities  Json     // string[]
  benefits          Json     // string[]
  salary            Json?    // { min, max, currency }
  salaryPublic       Boolean  @default(false) // when true, show salary on public job board; when false, staff-only
  experience        String?   // free-text for job ad display
  education         String?   // free-text for job ad display
  minYearsExperience Int?     // structured: filter candidates by experience >= this
  educationLevel    String?   // structured: e.g. "High School" | "Bachelor" | "Master" | "PhD" | "Any"
  educationQualification String?  @db.Text // specific degree for filtering: e.g. "MBA", "Bachelor of Commerce", "MSc Computer Science"
  requiredCertifications String?  @db.Text // required professional certs for filtering: e.g. "CPA", "CFA", "PMP"
  skills            Json     // string[]
  isActive          Boolean  @default(true)
  applicationCount  Int      @default(0)
  views             Int      @default(0)
  applicationStartAt DateTime?  // when null, job is open immediately; when set, only visible/apply after this time
  applicationDeadline DateTime?
  clientId          String?
  concealCompany    Boolean  @default(false) // when true, job board shows "Confidential" instead of company name
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  applications Application[]
  scheduleBreaks InterviewScheduleBreak[]
  requisitionApprovals JobRequisitionApproval[]

  @@index([isActive, postedDate(sort: Desc)])
  @@index([category])
  @@index([location])
  @@index([clientId])
  @@index([referenceId])
  @@index([slug])
}

model Candidate {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  location     String?
  nationality  String?  // Stage 1: candidate profile
  homeCounty   String?  // Stage 1: home county
  experience   Int      @default(0) // years
  education    String?  @db.Text
  resumePath   String?  // server path or storage URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications Application[]

  @@unique([email])
  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@index([nationality])
  @@index([homeCounty])
}

model Application {
  id          String   @id @default(cuid())
  jobId       String
  candidateId String
  status      ApplicationStatus @default(pending)
  appliedDate DateTime @default(now())
  coverLetter         String?  @db.Text
  resumePath          String?  // CV (Stage 4)
  salaryExpectations  String?  @db.Text // required from candidate on application form
  notes               String?  @db.Text // internal staff notes
  formData            Json?    // Stage 2–5: education, employment, certifications, declarations
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job        Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate  Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviews Interview[]
  views      ApplicationView[]
  offerApprovals JobOfferApproval[]
  hireConversion ApplicationHireConversion?

  @@index([jobId])
  @@index([status])
  @@index([appliedDate(sort: Desc)])
  @@index([candidateId])
  @@index([jobId, status]) // for dashboard filters
}

model ApplicationView {
  applicationId String
  userId        String
  viewedAt      DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([applicationId, userId])
  @@index([userId])
  @@index([applicationId])
}

model Interview {
  id                   String              @id @default(cuid())
  applicationId        String
  scheduledAt          DateTime
  durationMinutes      Int                 @default(45) // 30 | 45 | 60
  type                 String              // phone | video | onsite
  locationOrLink       String?             @db.Text // meeting link or address
  notes                String?             @db.Text
  status               InterviewStatus     @default(scheduled)
  inviteSentAt         DateTime?           // when official invite email was sent
  officialLetterPath   String?             // optional PDF for government clients
  confirmationStatus   ConfirmationStatus  @default(pending) // candidate response to invite
  confirmationNotes    String?             @db.Text // e.g. reschedule reason
  confirmationAt       DateTime?           // when candidate responded
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scorecards  InterviewScorecard[]

  @@index([applicationId])
  @@index([scheduledAt])
  @@index([status])
}

/// Calendar breaks (lunch, buffers) on a job’s interview schedule — shown in UI and PDF/HTML export.
model InterviewScheduleBreak {
  id               String   @id @default(cuid())
  jobId            String
  scheduledAt      DateTime // start of break (Nairobi wall time stored as UTC instant)
  durationMinutes  Int      @default(15)
  label            String   @default("Break") // e.g. Lunch, Coffee, Buffer
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([scheduledAt])
}

enum ConfirmationStatus {
  pending
  confirmed
  declined
  reschedule_requested
  withdrawn
}

enum ApplicationStatus {
  pending
  reviewed
  shortlisted
  rejected
  hired
}

enum InterviewStatus {
  scheduled
  completed
  cancelled
}

enum AtsApprovalStatus {
  pending
  approved
  rejected
}

enum AtsOfferDecision {
  strong_yes
  yes
  hold
  no
}

model JobRequisitionApproval {
  id               String            @id @default(cuid())
  jobId             String
  requestedByUserId String
  approverUserId    String
  status            AtsApprovalStatus @default(pending)
  notes             String?           @db.Text
  actedAt           DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@index([approverUserId, status])
