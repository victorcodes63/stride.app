  userId        String
  leaveTypeId   String
  year          Int
  entitledDays  Int      @default(0)
  usedDays      Int      @default(0)
  carriedOver   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

