// --- Accounts / finance (dashboard) ---

enum AccountsClientType {
  outsourcing
  recruitment
  custom
}

model AccountsClient {
  id                  String             @id @default(cuid())
  type                AccountsClientType
  /// Optional link to outsourcing client (one accounting profile per outsourcing client)
  outsourcingClientId String?            @unique
  /// Optional link to recruitment employer Client
  recruitmentClientId String?            @unique
  name                String
  currency            String             @default("KES")
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  /// Internal context: engagement description, billable setup, etc. Not shown on invoice PDF.
  billingNotes        String?            @db.Text
  /// Legacy field from per-client invoice numbering (global invoice sequence now used).
  nextInvoiceNumber    Int @default(1)
  /// Per-client sequential credit note number
  nextCreditNoteNumber Int @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  outsourcingClient OutsourcingClient? @relation(fields: [outsourcingClientId], references: [id], onDelete: SetNull)
  recruitmentClient Client?            @relation(fields: [recruitmentClientId], references: [id], onDelete: SetNull)

  contracts      AccountsContract[]
  invoices       AccountsInvoice[]
  creditNotes    AccountsCreditNote[]
  clientPayments AccountsClientPayment[]
  staffAccess    AccountsStaffAccess[]
  payrolls       Payroll[]

  @@index([type])
  @@index([name])
}

model AccountsStaffAccess {
  id               String  @id @default(cuid())
  userId           String
  /// If null, permissions apply across all accounts clients for this user.
  accountsClientId String?

  canManageContracts Boolean @default(false)
  canManageInvoices  Boolean @default(false)
  canManagePayments  Boolean @default(false)
  canManageVendors   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client AccountsClient? @relation(fields: [accountsClientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountsClientId])
  @@unique([userId, accountsClientId])
}

model AccountsContract {
  id        String   @id @default(cuid())
  clientId  String
  title     String?
  reference String?
  startDate DateTime? @db.Date
  endDate   DateTime  @db.Date
  /// When true, no more expiry reminders (including weekly post-expiry).
  remindersDisabled Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    AccountsClient      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  managers  ContractManager[]
  invoices  AccountsInvoice[]
  reminders ContractReminderSent[]

  @@index([clientId])
  @@index([endDate])
}

model ContractManager {
  id         String @id @default(cuid())
  contractId String
  userId     String

  contract AccountsContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contractId, userId])
  @@index([userId])
}

enum ContractReminderKind {
  two_months
  one_month
  fourteen_days
  seven_days
  expiry_day
  expired_weekly
}

/// Audit log for contract reminders (milestones once each; weekly can repeat).
model ContractReminderSent {
  id         String               @id @default(cuid())
  contractId String
  kind       ContractReminderKind
  sentAt     DateTime             @default(now())

  contract AccountsContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, kind, sentAt])
}

enum AccountsInvoiceStatus {
  unpaid
  partial
  paid
}

/// Which 3rd Park HRIS bank account appears on the invoice PDF.
enum AccountsInvoicePaymentBank {
  payroll_only
  consultancy_fees
}

model AccountsInvoice {
  id            String                @id @default(cuid())
  clientId      String
  contractId    String?
  invoiceNumber Int
  issueDate     DateTime              @db.Date
  dueDate       DateTime?             @db.Date
  taxDate       DateTime?             @db.Date
  currency      String                @default("KES")
  /// Basis points: 1600 = 16.00%
  vatRateBps    Int                   @default(1600)
  /// Optional manual final total override (incl. VAT) for ETIMS alignment.
  totalOverrideIncVat Decimal?        @db.Decimal(14, 2)
  status        AccountsInvoiceStatus @default(unpaid)
  /// Bank details block on invoice: payroll remittance vs consultancy & other fees.
  paymentBank   AccountsInvoicePaymentBank @default(consultancy_fees)
  notes         String?               @db.Text
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  accountsClient AccountsClient    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contract       AccountsContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  lines          AccountsInvoiceLine[]
  allocations    AccountsInvoicePaymentAllocation[]
  creditNotes    AccountsCreditNote[]

  @@unique([clientId, invoiceNumber])
  @@unique([invoiceNumber])
  @@index([clientId])
  @@index([issueDate])
  @@index([status])
}

/// Credit note correcting / reducing amounts billed on a sales invoice (same VAT rules as invoice lines).
model AccountsCreditNote {
  id                String   @id @default(cuid())
  clientId          String
  originalInvoiceId String
  creditNoteNumber  Int
  issueDate         DateTime @db.Date
  currency          String   @default("KES")
  vatRateBps        Int      @default(1600)
  /// Denormalized total incl. VAT at issue (for balances & reporting).
  totalIncVat       Decimal  @db.Decimal(14, 2)
  paymentBank       AccountsInvoicePaymentBank @default(consultancy_fees)
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client          AccountsClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  originalInvoice AccountsInvoice @relation(fields: [originalInvoiceId], references: [id], onDelete: Cascade)
  lines           AccountsCreditNoteLine[]

  @@unique([clientId, creditNoteNumber])
  @@index([clientId])
  @@index([originalInvoiceId])
}

model AccountsCreditNoteLine {
  id           String   @id @default(cuid())
  creditNoteId String
  item         String
  description  String?  @db.Text
  amountExVat  Decimal  @db.Decimal(14, 2)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  creditNote AccountsCreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

model AccountsInvoiceLine {
  id           String   @id @default(cuid())
  invoiceId    String
  item         String
  description  String?  @db.Text
  amountExVat  Decimal  @db.Decimal(14, 2)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  invoice AccountsInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model AccountsClientPayment {
  id         String   @id @default(cuid())
  clientId   String
  receivedAt DateTime @db.Date
  amount     Decimal  @db.Decimal(14, 2)
  reference  String?
  method     String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client      AccountsClient                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  allocations AccountsInvoicePaymentAllocation[]

  @@index([clientId])
  @@index([receivedAt])
}

model AccountsInvoicePaymentAllocation {
  id        String  @id @default(cuid())
  paymentId String
  invoiceId String
  amount    Decimal @db.Decimal(14, 2)

  payment AccountsClientPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice AccountsInvoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([invoiceId])
}

enum AccountsVendorBillStatus {
  unpaid
  partial
  paid
}

model AccountsVendor {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  currency     String   @default("KES")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bills    AccountsVendorBill[]
  payments AccountsVendorPayment[]

  @@index([name])
}

model AccountsVendorBill {
  id         String                   @id @default(cuid())
  vendorId   String
  billRef    String?
  issueDate  DateTime                 @db.Date
  dueDate    DateTime?                @db.Date
  currency   String                   @default("KES")
  vatRateBps Int                      @default(1600)
  status     AccountsVendorBillStatus @default(unpaid)
  notes      String?                  @db.Text
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  vendor      AccountsVendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  lines       AccountsVendorBillLine[]
  allocations AccountsVendorPaymentAllocation[]

  @@index([vendorId])
  @@index([issueDate])
}

model AccountsVendorBillLine {
  id          String   @id @default(cuid())
  billId      String
  item        String
  description String?  @db.Text
  amountExVat Decimal  @db.Decimal(14, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  bill AccountsVendorBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

model AccountsVendorPayment {
  id        String   @id @default(cuid())
  vendorId  String
  paidAt    DateTime @db.Date
  amount    Decimal  @db.Decimal(14, 2)
  reference String?
  method    String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor      AccountsVendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  allocations AccountsVendorPaymentAllocation[]

  @@index([vendorId])
  @@index([paidAt])
}

model AccountsVendorPaymentAllocation {
  id        String  @id @default(cuid())
  paymentId String
  billId    String
  amount    Decimal @db.Decimal(14, 2)

  payment AccountsVendorPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bill    AccountsVendorBill    @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([billId])
}

model StaffNotification {
  id         String    @id @default(cuid())
  userId     String?
  essPortalUserId String?
  title      String
  body       String    @db.Text
  readAt     DateTime?
  href       String?
  contractId String?
  event      String?
  priority   String    @default("info")
  createdAt  DateTime  @default(now())

  user User? @relation("StaffUserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  essPortalUser EssPortalUser? @relation("EssUserNotifications", fields: [essPortalUserId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([essPortalUserId, createdAt])
  @@index([readAt])
  @@index([event, priority])
}

model SchedulerLock {
  key       String   @id
  lastRunAt DateTime @default(now()) @updatedAt
}

model Insight {
  id        String   @id @default(cuid())
  slug      String?  @unique // URL-safe e.g. pay-transparency for /insights/[slug]
  title     String   @db.Text
  excerpt   String   @db.Text
  body      String?  @db.Text // optional full article content; shown on /insights/[slug]
  author    String   // e.g. "3rd Park HRIS" or staff name
  category  String   // e.g. "Uncategorized", "Job Hunting Tips", "HR Outsourcing"
  url       String   @db.Text // external link when no slug; else /insights/[slug]
  image    String   @db.Text // path or URL for featured image (from upload or external)
  imageTitle String?  // optional caption/title for the featured image, stored like CV metadata
  publishedAt DateTime @default(now()) // used for ordering and "date" display
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publishedAt(sort: Desc)])
  @@index([category])
  @@index([slug])
}
