// Eagle HR ATS - Scalable schema for 16k+ applications/year
// Use PostgreSQL in production (Vercel Postgres, Neon, Supabase, or self-hosted)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Client companies; jobs can be tied to a client and shown publicly or anonymously (recruitment only)
model Client {
  id           String   @id @default(cuid())
  name         String
  isAnonymous  Boolean  @default(false) // when true, job board shows "Confidential" instead of client name
  contactName  String?  // primary contact person name
  contactEmail String?  // primary contact email
  contactPhone String?  // primary contact phone
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs Job[]

  @@index([name])
}

// Outsourcing clients – companies we provide HR outsourcing for (separate from recruitment clients)
model OutsourcingClient {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Tax & registration (Kenya)
  kraPin                 String?
  nssfEmployerNumber     String?
  nhifEmployerNumber     String?
  companyRegistrationNumber String?
  vatNumber              String?

  // Banking & billing
  bankName               String?
  bankAccountNumber      String?
  bankBranch             String?
  bankSwiftCode          String?
  currency               String?  @default("KES")
  billingCycle           String?  // monthly | bi_weekly | weekly
  serviceFeeType         String?  // fixed | percentage | per_employee
  serviceFeeAmount       Decimal? @db.Decimal(12, 2)
  paymentTerms           String?  // e.g. Net 15, Net 30, due on receipt

  // Address
  postalAddress          String?
  county                 String?

  // Contract
  contractStartDate      DateTime?
  contractEndDate        DateTime?

  // Employee IDs: auto {prefix}-001 per client; override prefix e.g. BW for "Blue Wave"
  employeeNumberPrefix   String?
  /// monthly = one payslip/stat run per month. biweekly = two period grosses; statutory on combined month gross, split for payslips.
  payrollFrequency       String?  @default("monthly")
  /// none | paye_only (NSSF/SHIF/AHL on employment gross only; PAYE on gross+leave; net + leave) | included_in_gross (leave in gross before all stat)
  leavePayMode           String?  @default("none")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departments Department[]
  employees   Employee[]

  @@index([name])
}

// Departments within an outsourcing client
model Department {
  id                  String   @id @default(cuid())
  outsourcingClientId String
  name                String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client    OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([outsourcingClientId])
}

// Employees of outsourcing clients (tied to client and optionally department)
model Employee {
  id                  String    @id @default(cuid())
  outsourcingClientId String
  departmentId        String?
  employeeNumber      String?   // internal EMP No. e.g. 001, 002
  firstName           String
  lastName            String
  email               String
  phone               String?
  idNumber            String?   // national ID
  kraPin              String?   // Kenya Revenue Authority PIN
  nssfNumber          String?   // National Social Security Fund
  nhifNumber          String?   // National Hospital Insurance Fund
  dateOfJoining       DateTime?
  jobTitle            String?
  /// Monthly basic pay (KES). Pre-fills payroll when you generate a month; edit per month if needed.
  baseSalary          Decimal?  @db.Decimal(12, 2)
  // Bank details for salary disbursement
  bankName            String?
  bankBranch          String?
  bankAccountNumber   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  client         OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  payrolls       Payroll[]
  leaveBalances  LeaveBalance[]
  leaveApplications LeaveApplication[]
  attendances    Attendance[]

  @@index([outsourcingClientId])
  @@index([departmentId])
  @@index([email])
}

// Payroll records (Kenyan jurisdiction: PAYE, NSSF, NHIF)
model Payroll {
  id          String   @id @default(cuid())
  employeeId  String
  month       Int      // 1-12
  year        Int
  basicPay    Decimal  @db.Decimal(12, 2)
  /// Bi-weekly: gross earned in 1st half of month (before monthly statutory combine)
  period1Gross Decimal? @db.Decimal(12, 2)
  period2Gross Decimal? @db.Decimal(12, 2)
  /// Bi-weekly: days present Mon–Sat per period. { period1: ["YYYY-MM-DD",...], period2: [...] }
  biweeklyAttendance Json?
  allowances  Json     @default("[]") // [{ name, amount }]
  deductions  Json     @default("[]") // [{ name, amount }]
  grossPay    Decimal  @db.Decimal(12, 2)
  leavePay    Decimal  @default(0) @db.Decimal(12, 2)
  paye        Decimal  @db.Decimal(12, 2) // PAYE tax
  nssf        Decimal  @db.Decimal(12, 2)
  nhif        Decimal  @db.Decimal(12, 2) // SHIF (2.75% gross)
  ahl         Decimal  @db.Decimal(12, 2) // Affordable Housing Levy 1.5% gross; pre-PAYE deduction
  netPay      Decimal  @db.Decimal(12, 2)
  status      PayrollStatus @default(draft)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([year, month])
}

enum PayrollStatus {
  draft
  approved
  paid
}

// Leave types (Annual, Sick, Maternity, etc.)
model LeaveType {
  id          String   @id @default(cuid())
  name        String   // e.g. Annual, Sick, Maternity, Paternity, Compassionate
  daysPerYear Int      @default(21) // default annual entitlement for Kenyan employment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leaveBalances      LeaveBalance[]
  leaveApplications  LeaveApplication[]
}

// Leave balance per employee per type per year
model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  year        Int
  balance     Int      @default(0) // days remaining
  used        Int      @default(0) // days used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType  LeaveType  @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
}

// Leave applications
model LeaveApplication {
  id          String        @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  days        Int
  status      LeaveStatus   @default(pending)
  reason      String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

enum LeaveStatus {
  pending
  approved
  rejected
}

// Attendance records (check-in/check-out)
model Attendance {
  id        String   @id @default(cuid())
  employeeId String
  date      DateTime @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

// Jobs can be synced from external ATS or managed in-app; id can match external system
model Job {
  id                String   @id @default(cuid())
  referenceId       String?  @unique // human-readable e.g. JOB-2026-0001; generated on create
  slug              String?  @unique // URL-safe e.g. senior-accountant-nairobi; used for /careers/apply/[slug]
  title             String
  company           String   // display name: client name or "Confidential" when client.isAnonymous
  location          String
  type              String   // Full Time | Part Time | Contract | Remote
  category          String
  postedDate        DateTime @default(now())
  description       String   @db.Text
  requirements      Json     // string[]
  responsibilities  Json     // string[]
  benefits          Json     // string[]
  salary            Json?    // { min, max, currency }
  salaryPublic       Boolean  @default(false) // when true, show salary on public job board; when false, staff-only
  experience        String?   // free-text for job ad display
  education         String?   // free-text for job ad display
  minYearsExperience Int?     // structured: filter candidates by experience >= this
  educationLevel    String?   // structured: e.g. "High School" | "Bachelor" | "Master" | "PhD" | "Any"
  educationQualification String?  @db.Text // specific degree for filtering: e.g. "MBA", "Bachelor of Commerce", "MSc Computer Science"
  requiredCertifications String?  @db.Text // required professional certs for filtering: e.g. "CPA", "CFA", "PMP"
  skills            Json     // string[]
  isActive          Boolean  @default(true)
  applicationCount  Int      @default(0)
  views             Int      @default(0)
  applicationStartAt DateTime?  // when null, job is open immediately; when set, only visible/apply after this time
  applicationDeadline DateTime?
  clientId          String?
  concealCompany    Boolean  @default(false) // when true, job board shows "Confidential" instead of company name
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  applications Application[]
  scheduleBreaks InterviewScheduleBreak[]

  @@index([isActive, postedDate(sort: Desc)])
  @@index([category])
  @@index([location])
  @@index([clientId])
  @@index([referenceId])
  @@index([slug])
}

model Candidate {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  location     String?
  nationality  String?  // Stage 1: candidate profile
  homeCounty   String?  // Stage 1: home county
  experience   Int      @default(0) // years
  education    String?  @db.Text
  resumePath   String?  // server path or storage URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications Application[]

  @@unique([email])
  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@index([nationality])
  @@index([homeCounty])
}

model Application {
  id          String   @id @default(cuid())
  jobId       String
  candidateId String
  status      ApplicationStatus @default(pending)
  appliedDate DateTime @default(now())
  coverLetter         String?  @db.Text
  resumePath          String?  // CV (Stage 4)
  salaryExpectations  String?  @db.Text // required from candidate on application form
  notes               String?  @db.Text // internal staff notes
  formData            Json?    // Stage 2–5: education, employment, certifications, declarations
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job        Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate  Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviews Interview[]
  views      ApplicationView[]

  @@index([jobId])
  @@index([status])
  @@index([appliedDate(sort: Desc)])
  @@index([candidateId])
  @@index([jobId, status]) // for dashboard filters
}

model ApplicationView {
  applicationId String
  userId        String
  viewedAt      DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([applicationId, userId])
  @@index([userId])
  @@index([applicationId])
}

model Interview {
  id                   String              @id @default(cuid())
  applicationId        String
  scheduledAt          DateTime
  durationMinutes      Int                 @default(45) // 30 | 45 | 60
  type                 String              // phone | video | onsite
  locationOrLink       String?             @db.Text // meeting link or address
  notes                String?             @db.Text
  status               InterviewStatus     @default(scheduled)
  inviteSentAt         DateTime?           // when official invite email was sent
  officialLetterPath   String?             // optional PDF for government clients
  confirmationStatus   ConfirmationStatus  @default(pending) // candidate response to invite
  confirmationNotes    String?             @db.Text // e.g. reschedule reason
  confirmationAt       DateTime?           // when candidate responded
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([scheduledAt])
  @@index([status])
}

/// Calendar breaks (lunch, buffers) on a job’s interview schedule — shown in UI and PDF/HTML export.
model InterviewScheduleBreak {
  id               String   @id @default(cuid())
  jobId            String
  scheduledAt      DateTime // start of break (Nairobi wall time stored as UTC instant)
  durationMinutes  Int      @default(15)
  label            String   @default("Break") // e.g. Lunch, Coffee, Buffer
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([scheduledAt])
}

enum ConfirmationStatus {
  pending
  confirmed
  declined
  reschedule_requested
  withdrawn
}

enum ApplicationStatus {
  pending
  reviewed
  shortlisted
  rejected
  hired
}

enum InterviewStatus {
  scheduled
  completed
  cancelled
}

// Staff members who can access the dashboard
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(staff)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  staffLeaveBalances     StaffLeaveBalance[]
  staffLeaveApplications StaffLeaveApplication[] @relation("StaffLeaveApplicant")
  staffLeaveReviews      StaffLeaveApplication[] @relation("StaffLeaveReviewer")

  @@index([email])
  @@index([isActive])
}

// --- Eagle HR internal staff leave (not outsourcing employees) ---

model StaffLeaveType {
  id                 String   @id @default(cuid())
  name               String
  daysPerYear        Int      @default(21)
  description        String?  @db.Text
  color              String?  // e.g. #043d4a
  requiresApproval   Boolean  @default(true)
  active             Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  balances      StaffLeaveBalance[]
  applications  StaffLeaveApplication[]

  @@index([active, sortOrder])
}

model StaffLeaveBalance {
  id            String   @id @default(cuid())
  userId        String
  leaveTypeId   String
  year          Int
  entitledDays  Int      @default(0)
  usedDays      Int      @default(0)
  carriedOver   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType StaffLeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId, year])
  @@index([userId, year])
}

model StaffLeaveApplication {
  id            String                        @id @default(cuid())
  userId        String
  leaveTypeId   String
  startDate     DateTime                      @db.Date
  endDate       DateTime                      @db.Date
  totalDays     Int
  reason        String?                       @db.Text
  status        StaffLeaveApplicationStatus   @default(pending)
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?                       @db.Text
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt

  user       User           @relation("StaffLeaveApplicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?          @relation("StaffLeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  leaveType  StaffLeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([startDate, endDate])
}

enum StaffLeaveApplicationStatus {
  pending
  approved
  rejected
  cancelled
}

enum UserRole {
  admin
  staff
  viewer
}

// Insights / blog articles managed by staff; shown on public /insights page
model Insight {
  id        String   @id @default(cuid())
  slug      String?  @unique // URL-safe e.g. pay-transparency for /insights/[slug]
  title     String   @db.Text
  excerpt   String   @db.Text
  body      String?  @db.Text // optional full article content; shown on /insights/[slug]
  author    String   // e.g. "Eagle HR" or staff name
  category  String   // e.g. "Uncategorized", "Job Hunting Tips", "HR Outsourcing"
  url       String   @db.Text // external link when no slug; else /insights/[slug]
  image    String   @db.Text // path or URL for featured image (from upload or external)
  imageTitle String?  // optional caption/title for the featured image, stored like CV metadata
  publishedAt DateTime @default(now()) // used for ordering and "date" display
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publishedAt(sort: Desc)])
  @@index([category])
  @@index([slug])
}
