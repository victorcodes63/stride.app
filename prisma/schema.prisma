// Eagle HR ATS - Scalable schema for 16k+ applications/year
// Use PostgreSQL in production (Vercel Postgres, Neon, Supabase, or self-hosted)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Client companies; jobs can be tied to a client and shown publicly or anonymously (recruitment only)
model Client {
  id           String   @id @default(cuid())
  name         String
  isAnonymous  Boolean  @default(false) // when true, job board shows "Confidential" instead of client name
  contactName  String?  // primary contact person name
  contactEmail String?  // primary contact email
  contactPhone String?  // primary contact phone
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs Job[]
  accountsClient AccountsClient?
  recruitmentPortalUsers RecruitmentClientPortalUser[]

  @@index([name])
}

/// View-only recruitment portal logins for employer contacts (separate from internal `User` / staff).
model RecruitmentClientPortalUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  clientId     String
  isActive     Boolean  @default(true)
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([isActive])
}

// Outsourcing clients – companies we provide HR outsourcing for (separate from recruitment clients)
model OutsourcingClient {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Tax & registration (Kenya)
  kraPin                 String?
  nssfEmployerNumber     String?
  nhifEmployerNumber     String?
  companyRegistrationNumber String?
  vatNumber              String?

  // Banking & billing
  bankName               String?
  bankAccountNumber      String?
  bankBranch             String?
  bankSwiftCode          String?
  currency               String?  @default("KES")
  billingCycle           String?  // monthly | bi_weekly | weekly
  serviceFeeType         String?  // fixed | percentage | per_employee
  serviceFeeAmount       Decimal? @db.Decimal(12, 2)
  paymentTerms           String?  // e.g. Net 15, Net 30, due on receipt

  // Address
  postalAddress          String?
  county                 String?

  // Contract
  contractStartDate      DateTime?
  contractEndDate        DateTime?

  // Employee IDs: auto {prefix}-001 per client; override prefix e.g. BW for "Blue Wave"
  employeeNumberPrefix   String?
  /// monthly = one payslip/stat run per month. biweekly = two period grosses; statutory on combined month gross, split for payslips.
  payrollFrequency       String?  @default("monthly")
  /// none | paye_only (NSSF/SHIF/AHL on employment gross only; PAYE on gross+leave; net + leave) | included_in_gross (leave in gross before all stat)
  leavePayMode           String?  @default("none")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departments Department[]
  employees   Employee[]
  accountsClient AccountsClient?

  @@index([name])
}

// Departments within an outsourcing client
model Department {
  id                  String   @id @default(cuid())
  outsourcingClientId String
  name                String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client    OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([outsourcingClientId])
}

// Employees of outsourcing clients (tied to client and optionally department)
model Employee {
  id                  String    @id @default(cuid())
  outsourcingClientId String
  departmentId        String?
  employeeNumber      String?   // internal EMP No. e.g. 001, 002
  firstName           String
  lastName            String
  email               String
  phone               String?
  idNumber            String?   // national ID
  kraPin              String?   // Kenya Revenue Authority PIN
  nssfNumber          String?   // National Social Security Fund
  nhifNumber          String?   // National Hospital Insurance Fund
  dateOfJoining       DateTime?
  jobTitle            String?
  /// Monthly basic pay (KES). Pre-fills payroll when you generate a month; edit per month if needed.
  baseSalary          Decimal?  @db.Decimal(12, 2)
  // Bank details for salary disbursement
  bankName            String?
  bankBranch          String?
  bankAccountNumber   String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  client         OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  payrolls       Payroll[]
  leaveBalances  LeaveBalance[]
  leaveApplications LeaveApplication[]
  attendances    Attendance[]

  @@index([outsourcingClientId])
  @@index([departmentId])
  @@index([email])
}

// Payroll records (Kenyan jurisdiction: PAYE, NSSF, NHIF)
model Payroll {
  id          String   @id @default(cuid())
  employeeId  String
  month       Int      // 1-12
  year        Int
  basicPay    Decimal  @db.Decimal(12, 2)
  /// Bi-weekly: gross earned in 1st half of month (before monthly statutory combine)
  period1Gross Decimal? @db.Decimal(12, 2)
  period2Gross Decimal? @db.Decimal(12, 2)
  /// Bi-weekly: days present Mon–Sat per period. { period1: ["YYYY-MM-DD",...], period2: [...] }
  biweeklyAttendance Json?
  allowances  Json     @default("[]") // [{ name, amount }]
  deductions  Json     @default("[]") // [{ name, amount }]
  grossPay    Decimal  @db.Decimal(12, 2)
  leavePay    Decimal  @default(0) @db.Decimal(12, 2)
  paye        Decimal  @db.Decimal(12, 2) // PAYE tax
  nssf        Decimal  @db.Decimal(12, 2)
  nhif        Decimal  @db.Decimal(12, 2) // SHIF (2.75% gross)
  ahl         Decimal  @db.Decimal(12, 2) // Affordable Housing Levy 1.5% gross; pre-PAYE deduction
  netPay      Decimal  @db.Decimal(12, 2)
  status      PayrollStatus @default(draft)
  /// Optional link to Accounts billing profile when one exists for the employee's outsourcing client.
  accountsClientId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  accountsClient AccountsClient? @relation(fields: [accountsClientId], references: [id], onDelete: SetNull)

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([year, month])
  @@index([accountsClientId])
}

enum PayrollStatus {
  draft
  approved
  paid
}

// Leave types (Annual, Sick, Maternity, etc.)
model LeaveType {
  id          String   @id @default(cuid())
  name        String   // e.g. Annual, Sick, Maternity, Paternity, Compassionate
  daysPerYear Int      @default(21) // default annual entitlement for Kenyan employment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leaveBalances      LeaveBalance[]
  leaveApplications  LeaveApplication[]
}

// Leave balance per employee per type per year
model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  year        Int
  balance     Int      @default(0) // days remaining
  used        Int      @default(0) // days used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType  LeaveType  @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
}

// Leave applications
model LeaveApplication {
  id          String        @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  days        Int
  status      LeaveStatus   @default(pending)
  reason      String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

enum LeaveStatus {
  pending
  approved
  rejected
}

// Attendance records (check-in/check-out)
model Attendance {
  id        String   @id @default(cuid())
  employeeId String
  date      DateTime @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

// Jobs can be synced from external ATS or managed in-app; id can match external system
model Job {
  id                String   @id @default(cuid())
  referenceId       String?  @unique // human-readable e.g. JOB-2026-0001; generated on create
  slug              String?  @unique // URL-safe e.g. senior-accountant-nairobi; used for /careers/apply/[slug]
  title             String
  company           String   // display name: client name or "Confidential" when client.isAnonymous
  location          String
  type              String   // Full Time | Part Time | Contract | Remote
  category          String
  postedDate        DateTime @default(now())
  description       String   @db.Text
  requirements      Json     // string[]
  responsibilities  Json     // string[]
  benefits          Json     // string[]
  salary            Json?    // { min, max, currency }
  salaryPublic       Boolean  @default(false) // when true, show salary on public job board; when false, staff-only
  experience        String?   // free-text for job ad display
  education         String?   // free-text for job ad display
  minYearsExperience Int?     // structured: filter candidates by experience >= this
  educationLevel    String?   // structured: e.g. "High School" | "Bachelor" | "Master" | "PhD" | "Any"
  educationQualification String?  @db.Text // specific degree for filtering: e.g. "MBA", "Bachelor of Commerce", "MSc Computer Science"
  requiredCertifications String?  @db.Text // required professional certs for filtering: e.g. "CPA", "CFA", "PMP"
  skills            Json     // string[]
  isActive          Boolean  @default(true)
  applicationCount  Int      @default(0)
  views             Int      @default(0)
  applicationStartAt DateTime?  // when null, job is open immediately; when set, only visible/apply after this time
  applicationDeadline DateTime?
  clientId          String?
  concealCompany    Boolean  @default(false) // when true, job board shows "Confidential" instead of company name
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  applications Application[]
  scheduleBreaks InterviewScheduleBreak[]

  @@index([isActive, postedDate(sort: Desc)])
  @@index([category])
  @@index([location])
  @@index([clientId])
  @@index([referenceId])
  @@index([slug])
}

model Candidate {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  location     String?
  nationality  String?  // Stage 1: candidate profile
  homeCounty   String?  // Stage 1: home county
  experience   Int      @default(0) // years
  education    String?  @db.Text
  resumePath   String?  // server path or storage URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications Application[]

  @@unique([email])
  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@index([nationality])
  @@index([homeCounty])
}

model Application {
  id          String   @id @default(cuid())
  jobId       String
  candidateId String
  status      ApplicationStatus @default(pending)
  appliedDate DateTime @default(now())
  coverLetter         String?  @db.Text
  resumePath          String?  // CV (Stage 4)
  salaryExpectations  String?  @db.Text // required from candidate on application form
  notes               String?  @db.Text // internal staff notes
  formData            Json?    // Stage 2–5: education, employment, certifications, declarations
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job        Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate  Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviews Interview[]
  views      ApplicationView[]

  @@index([jobId])
  @@index([status])
  @@index([appliedDate(sort: Desc)])
  @@index([candidateId])
  @@index([jobId, status]) // for dashboard filters
}

model ApplicationView {
  applicationId String
  userId        String
  viewedAt      DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([applicationId, userId])
  @@index([userId])
  @@index([applicationId])
}

model Interview {
  id                   String              @id @default(cuid())
  applicationId        String
  scheduledAt          DateTime
  durationMinutes      Int                 @default(45) // 30 | 45 | 60
  type                 String              // phone | video | onsite
  locationOrLink       String?             @db.Text // meeting link or address
  notes                String?             @db.Text
  status               InterviewStatus     @default(scheduled)
  inviteSentAt         DateTime?           // when official invite email was sent
  officialLetterPath   String?             // optional PDF for government clients
  confirmationStatus   ConfirmationStatus  @default(pending) // candidate response to invite
  confirmationNotes    String?             @db.Text // e.g. reschedule reason
  confirmationAt       DateTime?           // when candidate responded
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([scheduledAt])
  @@index([status])
}

/// Calendar breaks (lunch, buffers) on a job’s interview schedule — shown in UI and PDF/HTML export.
model InterviewScheduleBreak {
  id               String   @id @default(cuid())
  jobId            String
  scheduledAt      DateTime // start of break (Nairobi wall time stored as UTC instant)
  durationMinutes  Int      @default(15)
  label            String   @default("Break") // e.g. Lunch, Coffee, Buffer
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([scheduledAt])
}

enum ConfirmationStatus {
  pending
  confirmed
  declined
  reschedule_requested
  withdrawn
}

enum ApplicationStatus {
  pending
  reviewed
  shortlisted
  rejected
  hired
}

enum InterviewStatus {
  scheduled
  completed
  cancelled
}

// Staff members who can access the dashboard
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(staff)
  /// Job function preset; drives leave approver queue etc. Admins may ignore visually but column still set.
  staffUserType StaffUserType @default(operations)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  staffLeaveBalances     StaffLeaveBalance[]
  staffLeaveApplications StaffLeaveApplication[] @relation("StaffLeaveApplicant")
  staffLeaveReviews      StaffLeaveApplication[] @relation("StaffLeaveReviewer")
  staffNotifications     StaffNotification[]
  accountsStaffAccess    AccountsStaffAccess[]
  contractManagers       ContractManager[]

  @@index([email])
  @@index([isActive])
}

// --- Eagle HR internal staff leave (not outsourcing employees) ---

model StaffLeaveType {
  id                 String   @id @default(cuid())
  name               String
  daysPerYear        Int      @default(21)
  description        String?  @db.Text
  color              String?  // e.g. #043d4a
  requiresApproval   Boolean  @default(true)
  active             Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  balances      StaffLeaveBalance[]
  applications  StaffLeaveApplication[]

  @@index([active, sortOrder])
}

model StaffLeaveBalance {
  id            String   @id @default(cuid())
  userId        String
  leaveTypeId   String
  year          Int
  entitledDays  Int      @default(0)
  usedDays      Int      @default(0)
  carriedOver   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType StaffLeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId, year])
  @@index([userId, year])
}

model StaffLeaveApplication {
  id            String                        @id @default(cuid())
  userId        String
  leaveTypeId   String
  startDate     DateTime                      @db.Date
  endDate       DateTime                      @db.Date
  totalDays     Int
  reason        String?                       @db.Text
  status        StaffLeaveApplicationStatus   @default(pending)
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?                       @db.Text
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt

  user       User           @relation("StaffLeaveApplicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?          @relation("StaffLeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  leaveType  StaffLeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([startDate, endDate])
}

enum StaffLeaveApplicationStatus {
  pending
  approved
  rejected
  cancelled
}

enum UserRole {
  admin
  staff
  viewer
}

/// Internal staff persona for permissions (not used for external recruitment client logins).
enum StaffUserType {
  operations
  business_manager
  finance
  director
}

// --- Accounts / finance (dashboard) ---

enum AccountsClientType {
  outsourcing
  recruitment
  custom
}

model AccountsClient {
  id                  String             @id @default(cuid())
  type                AccountsClientType
  /// Optional link to outsourcing client (one accounting profile per outsourcing client)
  outsourcingClientId String?            @unique
  /// Optional link to recruitment employer Client
  recruitmentClientId String?            @unique
  name                String
  currency            String             @default("KES")
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  /// Internal context: engagement description, billable setup, etc. Not shown on invoice PDF.
  billingNotes        String?            @db.Text
  /// Per-client sequential invoice number (manual invoices)
  nextInvoiceNumber    Int @default(1)
  /// Per-client sequential credit note number
  nextCreditNoteNumber Int @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  outsourcingClient OutsourcingClient? @relation(fields: [outsourcingClientId], references: [id], onDelete: SetNull)
  recruitmentClient Client?            @relation(fields: [recruitmentClientId], references: [id], onDelete: SetNull)

  contracts      AccountsContract[]
  invoices       AccountsInvoice[]
  creditNotes    AccountsCreditNote[]
  clientPayments AccountsClientPayment[]
  staffAccess    AccountsStaffAccess[]
  payrolls       Payroll[]

  @@index([type])
  @@index([name])
}

model AccountsStaffAccess {
  id               String  @id @default(cuid())
  userId           String
  /// If null, permissions apply across all accounts clients for this user.
  accountsClientId String?

  canManageContracts Boolean @default(false)
  canManageInvoices  Boolean @default(false)
  canManagePayments  Boolean @default(false)
  canManageVendors   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client AccountsClient? @relation(fields: [accountsClientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountsClientId])
  @@unique([userId, accountsClientId])
}

model AccountsContract {
  id        String   @id @default(cuid())
  clientId  String
  title     String?
  reference String?
  startDate DateTime? @db.Date
  endDate   DateTime  @db.Date
  /// When true, no more expiry reminders (including weekly post-expiry).
  remindersDisabled Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    AccountsClient      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  managers  ContractManager[]
  invoices  AccountsInvoice[]
  reminders ContractReminderSent[]

  @@index([clientId])
  @@index([endDate])
}

model ContractManager {
  id         String @id @default(cuid())
  contractId String
  userId     String

  contract AccountsContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contractId, userId])
  @@index([userId])
}

enum ContractReminderKind {
  two_months
  one_month
  fourteen_days
  seven_days
  expiry_day
  expired_weekly
}

/// Audit log for contract reminders (milestones once each; weekly can repeat).
model ContractReminderSent {
  id         String               @id @default(cuid())
  contractId String
  kind       ContractReminderKind
  sentAt     DateTime             @default(now())

  contract AccountsContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, kind, sentAt])
}

enum AccountsInvoiceStatus {
  unpaid
  partial
  paid
}

/// Which Eagle HR bank account appears on the invoice PDF.
enum AccountsInvoicePaymentBank {
  payroll_only
  consultancy_fees
}

model AccountsInvoice {
  id            String                @id @default(cuid())
  clientId      String
  contractId    String?
  invoiceNumber Int
  issueDate     DateTime              @db.Date
  dueDate       DateTime?             @db.Date
  taxDate       DateTime?             @db.Date
  currency      String                @default("KES")
  /// Basis points: 1600 = 16.00%
  vatRateBps    Int                   @default(1600)
  status        AccountsInvoiceStatus @default(unpaid)
  /// Bank details block on invoice: payroll remittance vs consultancy & other fees.
  paymentBank   AccountsInvoicePaymentBank @default(consultancy_fees)
  notes         String?               @db.Text
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  accountsClient AccountsClient    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contract       AccountsContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  lines          AccountsInvoiceLine[]
  allocations    AccountsInvoicePaymentAllocation[]
  creditNotes    AccountsCreditNote[]

  @@unique([clientId, invoiceNumber])
  @@index([clientId])
  @@index([issueDate])
  @@index([status])
}

/// Credit note correcting / reducing amounts billed on a sales invoice (same VAT rules as invoice lines).
model AccountsCreditNote {
  id                String   @id @default(cuid())
  clientId          String
  originalInvoiceId String
  creditNoteNumber  Int
  issueDate         DateTime @db.Date
  currency          String   @default("KES")
  vatRateBps        Int      @default(1600)
  /// Denormalized total incl. VAT at issue (for balances & reporting).
  totalIncVat       Decimal  @db.Decimal(14, 2)
  paymentBank       AccountsInvoicePaymentBank @default(consultancy_fees)
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client          AccountsClient  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  originalInvoice AccountsInvoice @relation(fields: [originalInvoiceId], references: [id], onDelete: Cascade)
  lines           AccountsCreditNoteLine[]

  @@unique([clientId, creditNoteNumber])
  @@index([clientId])
  @@index([originalInvoiceId])
}

model AccountsCreditNoteLine {
  id           String   @id @default(cuid())
  creditNoteId String
  item         String
  description  String?  @db.Text
  amountExVat  Decimal  @db.Decimal(14, 2)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  creditNote AccountsCreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

model AccountsInvoiceLine {
  id           String   @id @default(cuid())
  invoiceId    String
  item         String
  description  String?  @db.Text
  amountExVat  Decimal  @db.Decimal(14, 2)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  invoice AccountsInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model AccountsClientPayment {
  id         String   @id @default(cuid())
  clientId   String
  receivedAt DateTime @db.Date
  amount     Decimal  @db.Decimal(14, 2)
  reference  String?
  method     String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client      AccountsClient                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  allocations AccountsInvoicePaymentAllocation[]

  @@index([clientId])
  @@index([receivedAt])
}

model AccountsInvoicePaymentAllocation {
  id        String  @id @default(cuid())
  paymentId String
  invoiceId String
  amount    Decimal @db.Decimal(14, 2)

  payment AccountsClientPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice AccountsInvoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([invoiceId])
}

enum AccountsVendorBillStatus {
  unpaid
  partial
  paid
}

model AccountsVendor {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?
  currency     String   @default("KES")
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bills    AccountsVendorBill[]
  payments AccountsVendorPayment[]

  @@index([name])
}

model AccountsVendorBill {
  id         String                   @id @default(cuid())
  vendorId   String
  billRef    String?
  issueDate  DateTime                 @db.Date
  dueDate    DateTime?                @db.Date
  currency   String                   @default("KES")
  vatRateBps Int                      @default(1600)
  status     AccountsVendorBillStatus @default(unpaid)
  notes      String?                  @db.Text
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  vendor      AccountsVendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  lines       AccountsVendorBillLine[]
  allocations AccountsVendorPaymentAllocation[]

  @@index([vendorId])
  @@index([issueDate])
}

model AccountsVendorBillLine {
  id          String   @id @default(cuid())
  billId      String
  item        String
  description String?  @db.Text
  amountExVat Decimal  @db.Decimal(14, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  bill AccountsVendorBill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

model AccountsVendorPayment {
  id        String   @id @default(cuid())
  vendorId  String
  paidAt    DateTime @db.Date
  amount    Decimal  @db.Decimal(14, 2)
  reference String?
  method    String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor      AccountsVendor                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  allocations AccountsVendorPaymentAllocation[]

  @@index([vendorId])
  @@index([paidAt])
}

model AccountsVendorPaymentAllocation {
  id        String  @id @default(cuid())
  paymentId String
  billId    String
  amount    Decimal @db.Decimal(14, 2)

  payment AccountsVendorPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bill    AccountsVendorBill    @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([billId])
}

model StaffNotification {
  id         String    @id @default(cuid())
  userId     String
  title      String
  body       String    @db.Text
  readAt     DateTime?
  href       String?
  contractId String?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([readAt])
}

model SchedulerLock {
  key       String   @id
  lastRunAt DateTime @default(now()) @updatedAt
}

model Insight {
  id        String   @id @default(cuid())
  slug      String?  @unique // URL-safe e.g. pay-transparency for /insights/[slug]
  title     String   @db.Text
  excerpt   String   @db.Text
  body      String?  @db.Text // optional full article content; shown on /insights/[slug]
  author    String   // e.g. "Eagle HR" or staff name
  category  String   // e.g. "Uncategorized", "Job Hunting Tips", "HR Outsourcing"
  url       String   @db.Text // external link when no slug; else /insights/[slug]
  image    String   @db.Text // path or URL for featured image (from upload or external)
  imageTitle String?  // optional caption/title for the featured image, stored like CV metadata
  publishedAt DateTime @default(now()) // used for ordering and "date" display
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publishedAt(sort: Desc)])
  @@index([category])
  @@index([slug])
}
