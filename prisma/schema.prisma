// 3rd Park HRIS - Scalable schema for 16k+ applications/year
// Use PostgreSQL in production (Vercel Postgres, Neon, Supabase, or self-hosted)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Legacy: optional link for Accounts (type=recruitment) and Job.clientId. Single-tenant recruitment
// uses RecruitmentSettings; do not add multiple "employer" clients for job posting.
model Client {
  id           String   @id @default(cuid())
  name         String
  isAnonymous  Boolean  @default(false) // legacy; prefer Job.concealCompany for confidential listings
  contactName  String?  // primary contact person name
  contactEmail String?  // primary contact email
  contactPhone String?  // primary contact phone
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs Job[]
  accountsClient AccountsClient?
  recruitmentPortalUsers RecruitmentClientPortalUser[]
  recruitmentSettingsLink RecruitmentSettings? @relation("RecruitmentLinkedClient")

  @@index([name])
}

/// Single row (id = "default"): the organization that owns careers / hiring (3rd Park or your org name).
model RecruitmentSettings {
  id             String   @id @default("default")
  employerName   String
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  /// Optional: one `Client` row for Accounts (recruitment) billing and legacy Job.clientId
  linkedClientId String?  @unique
  linkedClient   Client?  @relation("RecruitmentLinkedClient", fields: [linkedClientId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// View-only recruitment portal logins for employer contacts (separate from internal `User` / staff).
model RecruitmentClientPortalUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  clientId     String
  isActive     Boolean  @default(true)
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([isActive])
}

// Outsourcing clients – companies we provide HR outsourcing for (separate from recruitment clients)
model OutsourcingClient {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Tax & registration (Kenya)
  kraPin                 String?
  nssfEmployerNumber     String?
  nhifEmployerNumber     String?
  companyRegistrationNumber String?
  vatNumber              String?

  // Banking & billing
  bankName               String?
  bankAccountNumber      String?
  bankBranch             String?
  bankSwiftCode          String?
  currency               String?  @default("KES")
  billingCycle           String?  // monthly | bi_weekly | weekly
  serviceFeeType         String?  // fixed | percentage | per_employee
  serviceFeeAmount       Decimal? @db.Decimal(12, 2)
  paymentTerms           String?  // e.g. Net 15, Net 30, due on receipt

  // Address
  postalAddress          String?
  county                 String?

  // Contract
  contractStartDate      DateTime?
  contractEndDate        DateTime?

  // Employee IDs: auto {prefix}-001 per client; override prefix e.g. BW for "Blue Wave"
  employeeNumberPrefix   String?
  /// monthly = one payslip/stat run per month. biweekly = two period grosses; statutory on combined month gross, split for payslips.
  payrollFrequency       String?  @default("monthly")
  /// none | paye_only (NSSF/SHIF/AHL on employment gross only; PAYE on gross+leave; net + leave) | included_in_gross (leave in gross before all stat)
  leavePayMode           String?  @default("none")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departments Department[]
  employees   Employee[]
  accountsClient AccountsClient?
  shiftTemplates ShiftTemplate[]
  rotaPeriods    RotaPeriod[]
  biometricDevices BiometricDevice[]
  statutoryReturns StatutoryReturn[]
  attendancePolicies AttendancePolicy[]
  leavePolicies      LeavePolicy[]
  attendanceEvents   AttendanceEvent[]
  attendanceDaySummaries AttendanceDaySummary[]

  @@index([name])
}

// --- Rota / shift scheduling (outsourcing employees) ---

/// Reusable shift pattern for an outsourcing client (e.g. Morning 06:00–14:00).
model ShiftTemplate {
  id                    String   @id @default(cuid())
  outsourcingClientId  String
  name                  String
  /// Minutes from midnight (0–1439). If endMinutes <= startMinutes, the shift crosses midnight.
  startMinutes         Int
  endMinutes           Int
  /// Unpaid break within the shift (excluded from weekly hours totals).
  breakMinutes         Int      @default(0)
  /// Optional color token for UI (e.g. hex).
  color                String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  client       OutsourcingClient  @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  assignments  ShiftAssignment[]

  @@index([outsourcingClientId, isActive])
}

/// A dated planning window (e.g. a week) for one outsourcing client.
model RotaPeriod {
  id                    String   @id @default(cuid())
  outsourcingClientId  String
  name                  String?
  startDate             DateTime  @db.Date
  endDate               DateTime  @db.Date
  status                RotaPeriodStatus @default(draft)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  client        OutsourcingClient  @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  assignments   ShiftAssignment[]

  @@index([outsourcingClientId, startDate])
  @@index([endDate])
}

enum RotaPeriodStatus {
  draft
  published
}

/// A concrete shift instance for an employee in a rota period.
model ShiftAssignment {
  id                 String   @id @default(cuid())
  rotaPeriodId       String
  employeeId         String
  shiftTemplateId   String?
  workDate          DateTime  @db.Date
  startsAt          DateTime
  endsAt            DateTime
  breakMinutes      Int       @default(0)
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rotaPeriod   RotaPeriod   @relation(fields: [rotaPeriodId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  attendanceEvents AttendanceEvent[]

  @@index([rotaPeriodId])
  @@index([employeeId, workDate])
  @@index([employeeId, startsAt])
}

// Departments within an outsourcing client
model Department {
  id                  String   @id @default(cuid())
  outsourcingClientId String
  name                String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client    OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([outsourcingClientId])
}

// Employees of outsourcing clients (tied to client and optionally department)
model Employee {
  id                  String    @id @default(cuid())
  outsourcingClientId String
  departmentId        String?
  managerEmployeeId   String?
  employeeNumber      String?   // internal EMP No. e.g. 001, 002
  firstName           String
  lastName            String
  /// Optional for casuals / hard-copy payslips; add when email delivery is needed.
  email               String?
  phone               String?
  idNumber            String?   // national ID
  kraPin              String?   // Kenya Revenue Authority PIN
  nssfNumber          String?   // National Social Security Fund
  nhifNumber          String?   // National Hospital Insurance Fund
  dateOfJoining       DateTime?
  jobTitle            String?
  /// Monthly basic pay (KES). Pre-fills payroll when you generate a month; edit per month if needed.
  baseSalary          Decimal?  @db.Decimal(12, 2)
  // Bank details for salary disbursement
  bankName            String?
  bankBranch          String?
  bankAccountNumber   String?
  employmentStatus    EmployeeEmploymentStatus @default(active)
  employmentStatusEffectiveFrom DateTime?
  employmentStatusEffectiveTo DateTime?
  employmentEndedAt   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  client         OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  manager        Employee?      @relation("EmployeeManager", fields: [managerEmployeeId], references: [id], onDelete: SetNull)
  subordinates   Employee[]     @relation("EmployeeManager")
  payrolls       Payroll[]
  leaveBalances  LeaveBalance[]
  leaveApplications LeaveApplication[]
  attendances    Attendance[]
  shiftAssignments ShiftAssignment[]
  biometricPunches BiometricPunch[]
  credentials    EmployeeCredential[]
  essPortalUsers EssPortalUser[]
  attendancePolicyAssignments AttendancePolicyAssignment[]
  leavePolicyAssignments LeavePolicyAssignment[]
  attendanceEvents AttendanceEvent[]
  attendanceSummaries AttendanceDaySummary[]
  attendanceExceptions AttendanceException[]
  leaveBalanceLedgers LeaveBalanceLedger[]
  documents      EmployeeDocument[]
  onboardingWorkflows OnboardingWorkflow[]
  disciplinaryCases   DisciplinaryCase[]
  grievancesFiled     Grievance[]
  grievancesAgainst   Grievance[] @relation("GrievanceAgainst")

  @@index([outsourcingClientId])
  @@index([departmentId])
  @@index([managerEmployeeId])
  @@index([employmentStatus])
  @@index([email])
  /// One national ID maps to at most one employee record system-wide (multiple NULL allowed).
  @@unique([idNumber])
}

model DisciplinaryCase {
  id           String  @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  caseNumber   String  @unique
  type         DisciplinaryCaseType
  status       DisciplinaryCaseStatus @default(OPEN)
  severity     DisciplinarySeverity   @default(MINOR)
  subject      String
  description  String   @db.Text
  incidentDate DateTime
  reportedDate DateTime @default(now())
  reportedById String
  reportedBy   User     @relation("CaseReporter", fields: [reportedById], references: [id])
  actions      DisciplinaryAction[]
  documents    DisciplinaryDocument[]
  resolution   String?  @db.Text
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?    @relation("CaseResolver", fields: [resolvedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([type])
}

model DisciplinaryAction {
  id                    String @id @default(cuid())
  caseId                 String
  disciplinaryCase       DisciplinaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type                   DisciplinaryActionType
  description            String   @db.Text
  actionDate             DateTime @default(now())
  performedById          String
  performedBy            User     @relation("DisciplinaryActionPerformer", fields: [performedById], references: [id])
  employeeResponse       String?  @db.Text
  employeeAcknowledged   Boolean  @default(false)
  acknowledgedAt         DateTime?
  nextActionDue          DateTime?
  letterGenerated        Boolean  @default(false)
  notes                  String?  @db.Text
  overrideSequence       Boolean  @default(false)
  overrideReason         String?  @db.Text

  @@index([caseId, actionDate])
}

model DisciplinaryDocument {
  id           String @id @default(cuid())
  caseId        String
  disciplinaryCase DisciplinaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title        String
  filePath     String
  fileName     String
  uploadedById String
  uploadedBy   User     @relation("DisciplinaryDocumentUploader", fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())

  @@index([caseId])
}

model Grievance {
  id                 String @id @default(cuid())
  employeeId         String
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  grievanceNumber    String @unique
  status             GrievanceStatus @default(SUBMITTED)
  subject            String
  description        String @db.Text
  category           GrievanceCategory
  againstId          String?
  against            Employee? @relation("GrievanceAgainst", fields: [againstId], references: [id])
  investigationNotes String? @db.Text
  resolution         String? @db.Text
  resolvedAt         DateTime?
  resolvedById       String?
  resolvedBy         User? @relation("GrievanceResolver", fields: [resolvedById], references: [id])
  submittedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}

enum DisciplinaryCaseType {
  MISCONDUCT
  POOR_PERFORMANCE
  POLICY_VIOLATION
  INSUBORDINATION
  ABSENTEEISM
  HARASSMENT
  NEGLIGENCE
  OTHER
}

enum DisciplinaryCaseStatus {
  OPEN
  UNDER_INVESTIGATION
  HEARING_SCHEDULED
  AWAITING_RESPONSE
  RESOLVED
  ESCALATED
  CLOSED
}

enum DisciplinarySeverity {
  MINOR
  MODERATE
  SERIOUS
  GROSS
}

enum DisciplinaryActionType {
  VERBAL_WARNING
  WRITTEN_WARNING
  FINAL_WARNING
  SHOW_CAUSE_LETTER
  HEARING
  SUSPENSION
  DEMOTION
  TERMINATION
  CASE_DISMISSED
}

enum GrievanceStatus {
  SUBMITTED
  UNDER_REVIEW
  INVESTIGATING
  RESOLVED
  ESCALATED
  WITHDRAWN
}

enum GrievanceCategory {
  WORKPLACE_SAFETY
  HARASSMENT
  DISCRIMINATION
  WORKLOAD
  MANAGEMENT
  COMPENSATION
  POLICY
  OTHER
}

enum EmployeeDocumentCategory {
  CONTRACT
  IDENTIFICATION
  QUALIFICATION
  PERFORMANCE
  DISCIPLINARY
  POLICY_ACKNOWLEDGMENT
  MEDICAL
  OTHER
}

model EmployeeDocument {
  id         String                   @id @default(cuid())
  employeeId String
  employee   Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  title      String
  category   EmployeeDocumentCategory
  filePath   String
  fileName   String
  fileSize   Int?
  mimeType   String?

  notes      String?
  uploadedBy String
  uploader   User                     @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)
  uploadedAt DateTime                 @default(now())

  @@index([employeeId])
  @@index([category])
}

enum EmployeeEmploymentStatus {
  active
  probation
  on_leave
  suspended
  terminated
}

enum WorkflowType {
  ONBOARDING
  OFFBOARDING
}

enum WorkflowStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OnboardingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  OVERDUE
}

model OnboardingTemplate {
  id        String   @id @default(cuid())
  name      String
  type      WorkflowType
  isDefault Boolean  @default(false)
  steps     OnboardingTemplateStep[]
  workflows OnboardingWorkflow[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OnboardingTemplateStep {
  id            String             @id @default(cuid())
  templateId    String
  template      OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  assignedRole  String
  order         Int
  dueDaysOffset Int      @default(3)
  isRequired    Boolean  @default(true)
  category      String?

  @@index([templateId, order])
}

model OnboardingWorkflow {
  id          String             @id @default(cuid())
  employeeId  String
  employee    Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  templateId  String
  template    OnboardingTemplate @relation(fields: [templateId], references: [id])
  type        WorkflowType
  status      WorkflowStatus     @default(IN_PROGRESS)
  startedAt   DateTime           @default(now())
  completedAt DateTime?
  tasks       OnboardingTask[]

  @@index([employeeId])
  @@index([status])
}

model OnboardingTask {
  id            String               @id @default(cuid())
  workflowId    String
  workflow      OnboardingWorkflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  assignedRole  String
  assignedToId  String?
  assignedTo    User?                @relation("OnboardingTaskAssignee", fields: [assignedToId], references: [id])
  category      String?
  order         Int
  isRequired    Boolean              @default(true)
  dueDate       DateTime?
  status        OnboardingTaskStatus @default(PENDING)
  completedAt   DateTime?
  completedById String?
  completedBy   User?                @relation("OnboardingTaskCompletedBy", fields: [completedById], references: [id])
  notes         String?
  documentId    String?

  @@index([workflowId, order])
  @@index([assignedRole, status])
  @@index([assignedToId, status])
}

enum AttendancePolicyMode {
  biometric_primary
  hybrid_override
  manual_primary
}

model AttendancePolicy {
  id                    String   @id @default(cuid())
  outsourcingClientId   String
  name                  String
  description           String?  @db.Text
  mode                  AttendancePolicyMode @default(hybrid_override)
  graceInMinutes        Int      @default(0)
  graceOutMinutes       Int      @default(0)
  minHalfDayMinutes     Int      @default(240)
  fullDayMinutes        Int      @default(480)
  requireManualApproval Boolean  @default(true)
  isDefault             Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  client       OutsourcingClient            @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  assignments  AttendancePolicyAssignment[]
  dailySummaries AttendanceDaySummary[]

  @@index([outsourcingClientId, isActive])
  @@index([outsourcingClientId, isDefault])
}

model AttendancePolicyAssignment {
  id                 String   @id @default(cuid())
  employeeId         String
  attendancePolicyId String
  effectiveFrom      DateTime @db.Date
  effectiveTo        DateTime? @db.Date
  isPrimary          Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendancePolicy AttendancePolicy @relation(fields: [attendancePolicyId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveFrom])
  @@index([attendancePolicyId, effectiveFrom])
}

enum LeaveAccrualMode {
  annual_grant
  monthly_accrual
}

model LeavePolicy {
  id                  String   @id @default(cuid())
  outsourcingClientId String
  name                String
  description         String?  @db.Text
  isDefault           Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client      OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  rules       LeavePolicyRule[]
  assignments LeavePolicyAssignment[]

  @@index([outsourcingClientId, isDefault])
  @@index([outsourcingClientId, isActive])
}

model LeavePolicyRule {
  id                  String   @id @default(cuid())
  leavePolicyId       String
  leaveTypeId         String
  accrualMode         LeaveAccrualMode @default(monthly_accrual)
  annualEntitlement   Int      @default(0)
  monthlyAccrualDays  Decimal  @default(0) @db.Decimal(6, 2)
  maxCarryForwardDays Int      @default(0)
  requiresApproval    Boolean  @default(true)
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  leavePolicy LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)
  leaveType   LeaveType   @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([leavePolicyId, leaveTypeId])
  @@index([leaveTypeId])
}

model LeavePolicyAssignment {
  id            String   @id @default(cuid())
  employeeId    String
  leavePolicyId String
  effectiveFrom DateTime @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leavePolicy LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveFrom])
  @@index([leavePolicyId, effectiveFrom])
}

enum AttendanceEventSource {
  biometric
  manual
  rota
}

enum AttendanceEventKind {
  check_in
  check_out
  break_start
  break_end
  override
}

model AttendanceEvent {
  id                 String   @id @default(cuid())
  employeeId         String
  outsourcingClientId String
  observedAt         DateTime
  workDate           DateTime @db.Date
  source             AttendanceEventSource
  kind               AttendanceEventKind
  biometricPunchId   String?
  shiftAssignmentId  String?
  createdByUserId    String?
  isApprovedOverride Boolean  @default(false)
  notes              String?  @db.Text
  metadata           Json?
  createdAt          DateTime @default(now())

  employee       Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client         OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  biometricPunch BiometricPunch?   @relation(fields: [biometricPunchId], references: [id], onDelete: SetNull)
  shiftAssignment ShiftAssignment? @relation(fields: [shiftAssignmentId], references: [id], onDelete: SetNull)
  createdByUser  User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId, workDate])
  @@index([outsourcingClientId, workDate])
  @@index([source, workDate])
}

enum AttendanceSummaryStatus {
  draft
  reconciled
  approved
}

model AttendanceDaySummary {
  id                 String   @id @default(cuid())
  employeeId         String
  outsourcingClientId String
  workDate           DateTime @db.Date
  attendancePolicyId String?
  firstInAt          DateTime?
  lastOutAt          DateTime?
  minutesWorked      Int      @default(0)
  lateMinutes        Int      @default(0)
  undertimeMinutes   Int      @default(0)
  overtimeMinutes    Int      @default(0)
  holidayOvertimeMinutes Int  @default(0)
  publicHolidayName  String?
  status             AttendanceSummaryStatus @default(draft)
  sourceBreakdown    Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client   OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  attendancePolicy AttendancePolicy? @relation(fields: [attendancePolicyId], references: [id], onDelete: SetNull)
  exceptions AttendanceException[]

  @@unique([employeeId, workDate])
  @@index([outsourcingClientId, workDate])
  @@index([status])
}

model PublicHoliday {
  id         String   @id @default(cuid())
  name       String
  date       DateTime?
  recurring  Boolean  @default(false)
  recurDay   Int?
  recurMonth Int?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date])
  @@index([date])
  @@index([recurMonth, recurDay])
}

enum AttendanceExceptionType {
  missing_check_in
  missing_check_out
  late_arrival
  early_departure
  mismatch_with_rota
  duplicate_events
  unapproved_manual_override
}

enum AttendanceExceptionStatus {
  open
  resolved
  ignored
}

model AttendanceException {
  id                     String   @id @default(cuid())
  employeeId             String
  attendanceDaySummaryId String?
  workDate               DateTime @db.Date
  type                   AttendanceExceptionType
  status                 AttendanceExceptionStatus @default(open)
  description            String   @db.Text
  resolvedByUserId       String?
  resolvedAt             DateTime?
  resolutionNotes        String?  @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  summary  AttendanceDaySummary? @relation(fields: [attendanceDaySummaryId], references: [id], onDelete: SetNull)
  resolvedByUser User? @relation(fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId, workDate])
  @@index([status, workDate])
}

enum LeaveBalanceLedgerEntryType {
  accrual
  debit
  carry_forward
  adjustment
}

model LeaveBalanceLedger {
  id            String   @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  year          Int
  entryType     LeaveBalanceLedgerEntryType
  days          Decimal  @db.Decimal(8, 2)
  sourceRef     String?
  notes         String?  @db.Text
  createdByUserId String?
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  createdByUser User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId, leaveTypeId, year])
  @@index([entryType])
}

enum CredentialCategory {
  medical_license
  specialist_certification
  life_support
  regulatory_compliance
  training
  other
}

enum CredentialStatus {
  active
  expiring_soon
  expired
  suspended
  revoked
}

model EmployeeCredential {
  id                 String           @id @default(cuid())
  employeeId         String
  category           CredentialCategory @default(medical_license)
  credentialName     String
  credentialNumber   String?
  issuingAuthority   String?
  issueDate          DateTime?        @db.Date
  expiryDate         DateTime?        @db.Date
  reminderDays       Int              @default(30)
  status             CredentialStatus @default(active)
  scopeOfPractice    String?
  notes              String?          @db.Text
  documentPath       String?
  verifiedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reminders CredentialReminderSent[]

  @@index([employeeId, category])
  @@index([expiryDate])
  @@index([status])
}

enum CredentialReminderKind {
  days_30
  days_14
  days_7
  overdue
}

model CredentialReminderSent {
  id           String                 @id @default(cuid())
  credentialId String
  userId       String
  kind         CredentialReminderKind
  sentOnYmd    String
  createdAt    DateTime               @default(now())

  credential EmployeeCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([credentialId, userId, kind, sentOnYmd])
  @@index([sentOnYmd])
  @@index([kind])
}

// Payroll records (Kenyan jurisdiction: PAYE, NSSF, NHIF)
model Payroll {
  id          String   @id @default(cuid())
  employeeId  String
  month       Int      // 1-12
  year        Int
  basicPay    Decimal  @db.Decimal(12, 2)
  /// Bi-weekly: gross earned in 1st half of month (before monthly statutory combine)
  period1Gross Decimal? @db.Decimal(12, 2)
  period2Gross Decimal? @db.Decimal(12, 2)
  /// Bi-weekly: days present Mon–Sat per period. { period1: ["YYYY-MM-DD",...], period2: [...] }
  biweeklyAttendance Json?
  allowances  Json     @default("[]") // [{ name, amount }]
  deductions  Json     @default("[]") // [{ name, amount }]
  grossPay    Decimal  @db.Decimal(12, 2)
  leavePay    Decimal  @default(0) @db.Decimal(12, 2)
  paye        Decimal  @db.Decimal(12, 2) // PAYE tax
  nssf        Decimal  @db.Decimal(12, 2)
  nhif        Decimal  @db.Decimal(12, 2) // SHIF (2.75% gross)
  ahl         Decimal  @db.Decimal(12, 2) // Affordable Housing Levy 1.5% gross; pre-PAYE deduction
  /// NITA employer levy (flat per employee per month); not deducted from employee net pay.
  nita        Decimal  @default(0) @db.Decimal(12, 2)
  netPay      Decimal  @db.Decimal(12, 2)
  status      PayrollStatus @default(draft)
  /// Optional link to Accounts billing profile when one exists for the employee's outsourcing client.
  accountsClientId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  accountsClient AccountsClient? @relation(fields: [accountsClientId], references: [id], onDelete: SetNull)

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([year, month])
  @@index([accountsClientId])
}

enum PayrollStatus {
  draft
  approved
  paid
}

enum StatutoryReturnStatus {
  draft
  review_ready
  filed
  paid
  overdue
}

enum StatutoryObligationType {
  paye
  nssf
  shif
  housing_levy
}

enum StatutoryItemStatus {
  pending
  prepared
  submitted
  paid
  overdue
}

/// Monthly compliance return per outsourcing client with audit-friendly statutory totals.
model StatutoryReturn {
  id                   String                @id @default(cuid())
  outsourcingClientId  String
  month                Int
  year                 Int
  currency             String                @default("KES")
  employeeCount        Int                   @default(0)
  payrollCount         Int                   @default(0)
  totalGrossPay        Decimal               @default(0) @db.Decimal(14, 2)
  totalPaye            Decimal               @default(0) @db.Decimal(14, 2)
  totalNssfEmployee    Decimal               @default(0) @db.Decimal(14, 2)
  totalNssfEmployer    Decimal               @default(0) @db.Decimal(14, 2)
  totalShif            Decimal               @default(0) @db.Decimal(14, 2)
  totalAhlEmployee     Decimal               @default(0) @db.Decimal(14, 2)
  totalAhlEmployer     Decimal               @default(0) @db.Decimal(14, 2)
  totalOtherDeductions Decimal               @default(0) @db.Decimal(14, 2)
  status               StatutoryReturnStatus @default(draft)
  submittedAt          DateTime?
  paidAt               DateTime?
  notes                String?               @db.Text
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  client OutsourcingClient     @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  items  StatutoryReturnItem[]

  @@unique([outsourcingClientId, month, year])
  @@index([year, month])
  @@index([status])
}

/// One line per statutory obligation (PAYE/NSSF/SHIF/AHL) for filing and payment workflow.
model StatutoryReturnItem {
  id                String                  @id @default(cuid())
  statutoryReturnId String
  obligationType    StatutoryObligationType
  authority         String
  employeeAmount    Decimal                 @default(0) @db.Decimal(14, 2)
  employerAmount    Decimal                 @default(0) @db.Decimal(14, 2)
  liabilityAmount   Decimal                 @default(0) @db.Decimal(14, 2)
  dueDate           DateTime                @db.Date
  status            StatutoryItemStatus     @default(pending)
  referenceNumber   String?
  paymentReference  String?
  submittedAt       DateTime?
  paidAt            DateTime?
  notes             String?                 @db.Text
  metadata          Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  statutoryReturn StatutoryReturn @relation(fields: [statutoryReturnId], references: [id], onDelete: Cascade)

  @@unique([statutoryReturnId, obligationType])
  @@index([dueDate])
  @@index([status])
}

// Leave types (Annual, Sick, Maternity, etc.)
model LeaveType {
  id          String   @id @default(cuid())
  name        String   // e.g. Annual, Sick, Maternity, Paternity, Compassionate
  daysPerYear Int      @default(21) // default annual entitlement for Kenyan employment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leaveBalances      LeaveBalance[]
  leaveApplications  LeaveApplication[]
  leavePolicyRules   LeavePolicyRule[]
  leaveBalanceLedgers LeaveBalanceLedger[]
}

// Leave balance per employee per type per year
model LeaveBalance {
  id          String   @id @default(cuid())
  employeeId  String
  leaveTypeId String
  year        Int
  balance     Int      @default(0) // days remaining
  used        Int      @default(0) // days used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType  LeaveType  @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId])
}

// Leave applications
model LeaveApplication {
  id          String        @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  days        Int
  status      LeaveStatus   @default(pending)
  reason      String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

enum LeaveStatus {
  pending
  approved
  rejected
}

// --- Biometric time terminals (M1) — device config is mutable; punches are append-only (no in-place updates).

/// Registered biometric device / time terminal (per outsourcing client).
model BiometricDevice {
  id                    String   @id @default(cuid())
  outsourcingClientId  String
  name                  String
  /// e.g. hikvision_isapi
  adapterKind          String
  /// Non-secret config (e.g. host). Secrets should stay in env / secret manager; references only here.
  config                Json?
  /// Last successful ISAPI poll instant (watermark for next `AcsEvent` time window).
  lastPollAt            DateTime?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  client OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  punches BiometricPunch[]

  @@index([outsourcingClientId])
  @@index([isActive])
  @@index([lastPollAt])
}

enum BiometricPunchSource {
  device
  csv
}

enum BiometricPunchDirection {
  in
  out
  unknown
}

/// Raw punch line from a device or CSV import — append-only; corrections are new rows.
model BiometricPunch {
  id                  String                   @id @default(cuid())
  biometricDeviceId  String
  /// Stable id for deduplication: vendor event id, or generated key for CSV rows.
  externalEventId    String
  observedAt         DateTime
  rawSubjectId      String
  /// Set when the subject maps cleanly to an employee; optional during ingestion.
  employeeId         String?
  rawPayload         Json?
  source            BiometricPunchSource
  direction         BiometricPunchDirection     @default(unknown)
  createdAt         DateTime                 @default(now())

  device   BiometricDevice @relation(fields: [biometricDeviceId], references: [id], onDelete: Cascade)
  employee Employee?        @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  attendanceEvents AttendanceEvent[]

  @@unique([biometricDeviceId, externalEventId])
  @@index([biometricDeviceId, observedAt])
  @@index([employeeId])
}

// Attendance records (check-in/check-out)
model Attendance {
  id        String   @id @default(cuid())
  employeeId String
  date      DateTime @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

// Jobs can be synced from external ATS or managed in-app; id can match external system
model Job {
  id                String   @id @default(cuid())
  referenceId       String?  @unique // human-readable e.g. JOB-2026-0001; generated on create
  slug              String?  @unique // URL-safe e.g. senior-accountant-nairobi; used for /careers/apply/[slug]
  title             String
  company           String   // display name: client name or "Confidential" when client.isAnonymous
  location          String
  type              String   // Full Time | Part Time | Contract | Remote
  category          String
  postedDate        DateTime @default(now())
  description       String   @db.Text
  requirements      Json     // string[]
  responsibilities  Json     // string[]
  benefits          Json     // string[]
  salary            Json?    // { min, max, currency }
  salaryPublic       Boolean  @default(false) // when true, show salary on public job board; when false, staff-only
  experience        String?   // free-text for job ad display
  education         String?   // free-text for job ad display
  minYearsExperience Int?     // structured: filter candidates by experience >= this
  educationLevel    String?   // structured: e.g. "High School" | "Bachelor" | "Master" | "PhD" | "Any"
  educationQualification String?  @db.Text // specific degree for filtering: e.g. "MBA", "Bachelor of Commerce", "MSc Computer Science"
  requiredCertifications String?  @db.Text // required professional certs for filtering: e.g. "CPA", "CFA", "PMP"
  skills            Json     // string[]
  isActive          Boolean  @default(true)
  applicationCount  Int      @default(0)
  views             Int      @default(0)
  applicationStartAt DateTime?  // when null, job is open immediately; when set, only visible/apply after this time
  applicationDeadline DateTime?
  clientId          String?
  concealCompany    Boolean  @default(false) // when true, job board shows "Confidential" instead of company name
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  applications Application[]
  scheduleBreaks InterviewScheduleBreak[]

  @@index([isActive, postedDate(sort: Desc)])
  @@index([category])
  @@index([location])
  @@index([clientId])
  @@index([referenceId])
  @@index([slug])
}

model Candidate {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  location     String?
  nationality  String?  // Stage 1: candidate profile
  homeCounty   String?  // Stage 1: home county
  experience   Int      @default(0) // years
  education    String?  @db.Text
  resumePath   String?  // server path or storage URL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications Application[]

  @@unique([email])
  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@index([nationality])
  @@index([homeCounty])
}

model Application {
  id          String   @id @default(cuid())
  jobId       String
  candidateId String
  status      ApplicationStatus @default(pending)
  appliedDate DateTime @default(now())
  coverLetter         String?  @db.Text
  resumePath          String?  // CV (Stage 4)
  salaryExpectations  String?  @db.Text // required from candidate on application form
  notes               String?  @db.Text // internal staff notes
  formData            Json?    // Stage 2–5: education, employment, certifications, declarations
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job        Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate  Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviews Interview[]
  views      ApplicationView[]

  @@index([jobId])
  @@index([status])
  @@index([appliedDate(sort: Desc)])
  @@index([candidateId])
  @@index([jobId, status]) // for dashboard filters
}

model ApplicationView {
  applicationId String
  userId        String
  viewedAt      DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([applicationId, userId])
  @@index([userId])
  @@index([applicationId])
}

model Interview {
  id                   String              @id @default(cuid())
  applicationId        String
  scheduledAt          DateTime
  durationMinutes      Int                 @default(45) // 30 | 45 | 60
  type                 String              // phone | video | onsite
  locationOrLink       String?             @db.Text // meeting link or address
  notes                String?             @db.Text
  status               InterviewStatus     @default(scheduled)
  inviteSentAt         DateTime?           // when official invite email was sent
  officialLetterPath   String?             // optional PDF for government clients
  confirmationStatus   ConfirmationStatus  @default(pending) // candidate response to invite
  confirmationNotes    String?             @db.Text // e.g. reschedule reason
  confirmationAt       DateTime?           // when candidate responded
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([scheduledAt])
  @@index([status])
}

/// Calendar breaks (lunch, buffers) on a job’s interview schedule — shown in UI and PDF/HTML export.
model InterviewScheduleBreak {
  id               String   @id @default(cuid())
  jobId            String
  scheduledAt      DateTime // start of break (Nairobi wall time stored as UTC instant)
  durationMinutes  Int      @default(15)
  label            String   @default("Break") // e.g. Lunch, Coffee, Buffer
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([scheduledAt])
}

enum ConfirmationStatus {
  pending
  confirmed
  declined
  reschedule_requested
  withdrawn
}

enum ApplicationStatus {
  pending
  reviewed
  shortlisted
  rejected
  hired
}

enum InterviewStatus {
  scheduled
  completed
  cancelled
}

// Staff members who can access the dashboard
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(staff)
  /// Job function preset; drives leave approver queue etc. Admins may ignore visually but column still set.
  staffUserType StaffUserType @default(operations)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  staffLeaveBalances     StaffLeaveBalance[]
  staffLeaveApplications StaffLeaveApplication[] @relation("StaffLeaveApplicant")
  staffLeaveReviews      StaffLeaveApplication[] @relation("StaffLeaveReviewer")
  staffNotifications     StaffNotification[] @relation("StaffUserNotifications")
  accountsStaffAccess    AccountsStaffAccess[]
  contractManagers       ContractManager[]
  credentialReminders    CredentialReminderSent[]
  essPortalUsersCreated  EssPortalUser[]          @relation("EssPortalUserCreator")
  permissionOverrides    UserPermissionOverride[]
  auditEvents            AuditEvent[]             @relation("AuditEventActor")
  updatedSettings        SystemSetting[]          @relation("SystemSettingUpdatedBy")
  attendanceEventsCreated AttendanceEvent[]
  attendanceExceptionsResolved AttendanceException[]
  leaveBalanceLedgersCreated LeaveBalanceLedger[]
  leaveApprovalSteps         LeaveApprovalStep[]
  leaveApprovalActions       LeaveApprovalAction[]
  uploadedEmployeeDocuments  EmployeeDocument[]
  onboardingAssignedTasks    OnboardingTask[] @relation("OnboardingTaskAssignee")
  onboardingCompletedTasks   OnboardingTask[] @relation("OnboardingTaskCompletedBy")
  reportedCases              DisciplinaryCase[] @relation("CaseReporter")
  resolvedCases              DisciplinaryCase[] @relation("CaseResolver")
  disciplinaryActions        DisciplinaryAction[] @relation("DisciplinaryActionPerformer")
  uploadedDisciplinaryDocuments DisciplinaryDocument[] @relation("DisciplinaryDocumentUploader")
  resolvedGrievances         Grievance[] @relation("GrievanceResolver")

  @@index([email])
  @@index([isActive])
}

model PermissionDefinition {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  module      String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]

  @@index([module])
}

model RolePermission {
  id           String   @id @default(cuid())
  role         UserRole
  permissionId String
  isAllowed    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  permission PermissionDefinition @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([permissionId])
}

model UserPermissionOverride {
  id           String   @id @default(cuid())
  userId       String
  permissionId String
  isAllowed    Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission PermissionDefinition @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}

model EssPortalUser {
  id                String   @id @default(cuid())
  employeeId        String?
  email             String   @unique
  name              String
  passwordHash      String
  role              EssPortalRole @default(employee)
  isActive          Boolean  @default(true)
  lastLoginAt       DateTime?
  mustResetPassword Boolean  @default(true)
  notes             String?  @db.Text
  createdByUserId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  createdByUser User?     @relation("EssPortalUserCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  notifications  StaffNotification[] @relation("EssUserNotifications")

  @@index([employeeId])
  @@index([isActive])
}

enum EssPortalRole {
  employee
  manager
  hr
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  action      String
  entityType  String
  entityId    String?
  route       String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([action])
  @@index([entityType, entityId])
}

model SystemSetting {
  key             String   @id
  value           Json
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy User? @relation("SystemSettingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
}

// --- 3rd Park HRIS internal staff leave (not outsourcing employees) ---

model StaffLeaveType {
