  onboardingCompletedTasks   OnboardingTask[] @relation("OnboardingTaskCompletedBy")
  reportedCases              DisciplinaryCase[] @relation("CaseReporter")
  resolvedCases              DisciplinaryCase[] @relation("CaseResolver")
  disciplinaryActions        DisciplinaryAction[] @relation("DisciplinaryActionPerformer")
  uploadedDisciplinaryDocuments DisciplinaryDocument[] @relation("DisciplinaryDocumentUploader")
