enum CredentialCategory {
  medical_license
  specialist_certification
  life_support
  regulatory_compliance
  training
  other
  /// Offshore survival, emergency response, H2S, OPITO safety suite, etc.
  oil_gas_safety
  /// IWCF / IADC surface & subsea well control, well intervention pressure control.
  oil_gas_well_control
  /// PTW, rigging & lifting, confined space, hot work, CompEx, site inductions.
  oil_gas_operations
}

enum CredentialStatus {
  active
  expiring_soon
  expired
  suspended
  revoked
}

enum AssetCategory {
  it_equipment
  furniture
  vehicle
  mobile_device
  tools
  uniform_ppe
  other
}

enum AssetStatus {
  available
  assigned
  maintenance
  retired
  lost
}

model CompanyAsset {
  id                  String        @id @default(cuid())
  outsourcingClientId String
  assetTag            String
  name                String
  description         String?       @db.Text
  category            AssetCategory @default(it_equipment)
  status              AssetStatus   @default(available)
  serialNumber        String?
  manufacturer        String?
  model               String?
  purchaseDate        DateTime?     @db.Date
  purchaseCost        Decimal?      @db.Decimal(12, 2)
  warrantyExpiry      DateTime?     @db.Date
