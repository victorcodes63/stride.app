enum WorkflowRunStatus {
  pending
  in_progress
  delegated
  escalated
  approved
  rejected
  completed
  cancelled
}

enum WorkflowTriggerType {
  event
  time
  manual
}

enum WorkflowRecipientKind {
  staff
  ess
}

enum NotificationDeliveryStatus {
  pending
  sent
  failed
  skipped_quiet_hours
  skipped_policy
}

model WorkflowRun {
  id               String            @id @default(cuid())
  module           String
  event            String
  entityType       String
  entityId         String
  entityCode       String?
  status           WorkflowRunStatus @default(pending)
  currentAssigneeUserId String?
  currentAssigneeEssPortalUserId String?
  delegatedFromUserId String?
  delegatedToUserId   String?
  delegatedAt      DateTime?
  escalatedAt      DateTime?
  startedAt        DateTime          @default(now())
  dueAt            DateTime?
  completedAt      DateTime?
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  currentAssigneeUser User? @relation("WorkflowCurrentAssigneeUser", fields: [currentAssigneeUserId], references: [id], onDelete: SetNull)
  currentAssigneeEssPortalUser EssPortalUser? @relation("WorkflowCurrentAssigneeEss", fields: [currentAssigneeEssPortalUserId], references: [id], onDelete: SetNull)
  delegatedFromUser User? @relation("WorkflowDelegatedFromUser", fields: [delegatedFromUserId], references: [id], onDelete: SetNull)
  delegatedToUser User? @relation("WorkflowDelegatedToUser", fields: [delegatedToUserId], references: [id], onDelete: SetNull)
  events WorkflowEvent[]
  notificationDeliveries NotificationDelivery[]

  @@index([module, status, dueAt])
  @@index([entityType, entityId])
  @@index([entityCode, status])
}

model WorkflowEvent {
  id              String               @id @default(cuid())
  workflowRunId   String
  triggerType     WorkflowTriggerType
  eventType       String
  recipientKind   WorkflowRecipientKind?
  recipientUserId String?
  recipientEssPortalUserId String?
  status          WorkflowRunStatus?
  dueAt           DateTime?
  metadata        Json?
  createdAt       DateTime             @default(now())

  workflowRun     WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  recipientUser   User?       @relation("WorkflowEventRecipientUser", fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientEssPortalUser EssPortalUser? @relation("WorkflowEventRecipientEss", fields: [recipientEssPortalUserId], references: [id], onDelete: SetNull)

  @@index([workflowRunId, createdAt])
  @@index([eventType, createdAt])
}

model NotificationPolicy {
  id                  String   @id @default(cuid())
  userId              String?  @unique
  essPortalUserId     String?  @unique
  inAppEnabled        Boolean  @default(true)
  emailEnabled        Boolean  @default(true)
  actionRequiredEmail Boolean  @default(true)
  urgentEmail         Boolean  @default(true)
  quietHoursEnabled   Boolean  @default(false)
  quietHoursStart     String?
  quietHoursEnd       String?
  timezone            String   @default("Africa/Nairobi")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  essPortalUser EssPortalUser? @relation(fields: [essPortalUserId], references: [id], onDelete: Cascade)
}

model NotificationDelivery {
  id                  String                   @id @default(cuid())
  staffNotificationId String?
  workflowRunId       String?
  event               String
  triggerType         WorkflowTriggerType      @default(event)
  recipientKind       WorkflowRecipientKind
  recipientUserId     String?
  recipientEssPortalUserId String?
  channel             String
  status              NotificationDeliveryStatus @default(pending)
  provider            String?
  error               String?
  metadata            Json?
  deliveredAt         DateTime?
  createdAt           DateTime                 @default(now())

  staffNotification StaffNotification? @relation(fields: [staffNotificationId], references: [id], onDelete: SetNull)
  workflowRun WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  recipientUser User? @relation("NotificationDeliveryRecipientUser", fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientEssPortalUser EssPortalUser? @relation("NotificationDeliveryRecipientEss", fields: [recipientEssPortalUserId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([recipientUserId, createdAt])
  @@index([recipientEssPortalUserId, createdAt])
  @@index([status, channel])
}

model SchedulerLock {
  key       String   @id
  lastRunAt DateTime @default(now()) @updatedAt
}

// --- Finance extensions: Chart of Accounts, GL, Expenses, Budgets, Petty Cash ---

enum AccountCategory {
  asset
  liability
  equity
  revenue
  expense
}

model ChartOfAccount {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  category    AccountCategory
  parentId    String?
  parent      ChartOfAccount? @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    ChartOfAccount[] @relation("AccountHierarchy")
  description String?         @db.Text
  isActive    Boolean         @default(true)
  isSystem    Boolean         @default(false)
  currency    String          @default("KES")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  journalLines GeneralLedgerEntry[]

  @@index([category])
  @@index([parentId])
  @@index([isActive])
}

model GeneralLedgerEntry {
  id            String   @id @default(cuid())
  accountId     String
  transactionId String
  date          DateTime @db.Date
  description   String
  debit         Decimal  @default(0) @db.Decimal(14, 2)
  credit        Decimal  @default(0) @db.Decimal(14, 2)
  reference     String?
  sourceType    String?
  sourceId      String?
  createdByUserId String?
  createdAt     DateTime @default(now())

  account ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([accountId, date])
  @@index([transactionId])
  @@index([date])
  @@index([sourceType, sourceId])
}

enum ExpenseClaimStatus {
  draft
  submitted
  approved
  rejected
  reimbursed
  cancelled
}

model ExpenseClaim {
  id              String             @id @default(cuid())
  claimNumber     String             @unique
  employeeId      String?
  userId          String?
  claimantName    String
  department      String?
  description     String             @db.Text
  currency        String             @default("KES")
  totalAmount     Decimal            @default(0) @db.Decimal(14, 2)
  status          ExpenseClaimStatus @default(draft)
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedByUserId String?
  rejectionReason String?            @db.Text
  reimbursedAt    DateTime?
  paymentReference String?
  notes           String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  items ExpenseClaimItem[]

  @@index([status])
  @@index([employeeId])
  @@index([userId])
  @@index([submittedAt])
}

enum ExpenseCategory {
  travel
  meals
  accommodation
  transport
  office_supplies
  communication
  training
  entertainment
  medical
  fuel
  parking
  utilities
  subscriptions
  other
}

model ExpenseClaimItem {
  id            String          @id @default(cuid())
  claimId       String
  date          DateTime        @db.Date
  category      ExpenseCategory @default(other)
  description   String
  amount        Decimal         @db.Decimal(14, 2)
  receiptPath   String?
  notes         String?         @db.Text
  createdAt     DateTime        @default(now())

  claim ExpenseClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([date])
  @@index([category])
}

enum BudgetStatus {
  draft
  active
  closed
  exceeded
}

enum BudgetPeriodType {
  monthly
  quarterly
  annual
}

model Budget {
  id             String           @id @default(cuid())
  name           String
  department     String?
  category       String?
  fiscalYear     Int
  periodType     BudgetPeriodType @default(annual)
  currency       String           @default("KES")
  allocatedAmount Decimal         @db.Decimal(14, 2)
  spentAmount    Decimal          @default(0) @db.Decimal(14, 2)
  status         BudgetStatus     @default(draft)
  startDate      DateTime         @db.Date
  endDate        DateTime         @db.Date
  notes          String?          @db.Text
  createdByUserId String?
  approvedByUserId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  items BudgetLineItem[]

  @@index([fiscalYear, status])
  @@index([department])
  @@index([startDate, endDate])
}

model BudgetLineItem {
  id              String   @id @default(cuid())
  budgetId        String
  name            String
  allocatedAmount Decimal  @db.Decimal(14, 2)
  spentAmount     Decimal  @default(0) @db.Decimal(14, 2)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

enum PettyCashStatus {
  open
  closed
  reconciled
}

model PettyCashFund {
  id              String          @id @default(cuid())
  name            String
  currency        String          @default("KES")
  floatAmount     Decimal         @db.Decimal(14, 2)
  currentBalance  Decimal         @default(0) @db.Decimal(14, 2)
  status          PettyCashStatus @default(open)
  custodianUserId String?
  custodianName   String?
  notes           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  transactions PettyCashTransaction[]

  @@index([status])
  @@index([custodianUserId])
}

enum PettyCashTransactionType {
  replenishment
  disbursement
  refund
}

model PettyCashTransaction {
  id             String                    @id @default(cuid())
  fundId         String
  type           PettyCashTransactionType
  amount         Decimal                   @db.Decimal(14, 2)
  date           DateTime                  @db.Date
  description    String
  category       String?
  receiptPath    String?
  approvedByUserId String?
  createdByUserId String?
  reference      String?
  notes          String?                   @db.Text
  createdAt      DateTime                  @default(now())

  fund PettyCashFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, date])
  @@index([type])
  @@index([date])
}

// --- SME Modules: Announcements, Training, Org Chart ---

enum AnnouncementStatus {
  draft
  published
  archived
}

enum AnnouncementPriority {
  low
  normal
  high
  urgent
}

model Announcement {
  id           String               @id @default(cuid())
  title        String
  body         String               @db.Text
  status       AnnouncementStatus   @default(draft)
  priority     AnnouncementPriority @default(normal)
  authorUserId String
  publishedAt  DateTime?
  expiresAt    DateTime?
  isPinned     Boolean              @default(false)
  targetDepartments Json?
  targetRoles       Json?
  attachmentPath    String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([status, publishedAt])
  @@index([isPinned, publishedAt])
  @@index([authorUserId])
  @@index([expiresAt])
}

enum TrainingStatus {
  scheduled
  in_progress
  completed
  cancelled
}

model TrainingProgram {
  id           String         @id @default(cuid())
  title        String
  description  String?        @db.Text
  category     String?
  provider     String?
  location     String?
  isOnline     Boolean        @default(false)
  startDate    DateTime?      @db.Date
  endDate      DateTime?      @db.Date
  durationHours Int?
  maxParticipants Int?
  cost         Decimal?       @db.Decimal(14, 2)
  currency     String         @default("KES")
  status       TrainingStatus @default(scheduled)
  notes        String?        @db.Text
  createdByUserId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  enrollments TrainingEnrollment[]
  materials   TrainingMaterial[]

  @@index([status])
  @@index([category])
  @@index([startDate])
}

enum EnrollmentStatus {
  enrolled
  in_progress
  completed
  withdrawn
  failed
}

model TrainingEnrollment {
  id            String           @id @default(cuid())
  programId     String
  employeeId    String?
  userId        String?
  enrolleeName  String
  status        EnrollmentStatus @default(enrolled)
  enrolledAt    DateTime         @default(now())
  completedAt   DateTime?
  score         Decimal?         @db.Decimal(5, 2)
  certificatePath String?
  feedback      String?          @db.Text
  notes         String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  program TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, employeeId])
  @@index([programId])
  @@index([employeeId])
  @@index([userId])
  @@index([status])
}

model TrainingMaterial {
  id          String   @id @default(cuid())
  programId   String
  title       String
  filePath    String?
  externalUrl String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  program TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId, sortOrder])
}

enum DocumentStatus {
  draft
  published
  archived
}

model CompanyDocument {
  id           String         @id @default(cuid())
  title        String
  description  String?        @db.Text
  category     String
  filePath     String
  fileName     String
  fileSize     Int?
  mimeType     String?
  version      String?
  status       DocumentStatus @default(published)
  isPublic     Boolean        @default(false)
  uploadedByUserId String
  department   String?
  tags         Json?
  effectiveDate DateTime?     @db.Date
  expiryDate   DateTime?      @db.Date
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([category])
  @@index([status])
  @@index([department])
  @@index([effectiveDate])
}

model Insight {
  id        String   @id @default(cuid())
  slug      String?  @unique // URL-safe e.g. pay-transparency for /insights/[slug]
  title     String   @db.Text
  excerpt   String   @db.Text
  body      String?  @db.Text // optional full article content; shown on /insights/[slug]
  author    String   // e.g. product name or staff name
  category  String   // e.g. "Uncategorized", "Job Hunting Tips", "HR Outsourcing"
  url       String   @db.Text // external link when no slug; else /insights/[slug]
  image    String   @db.Text // path or URL for featured image (from upload or external)
  imageTitle String?  // optional caption/title for the featured image, stored like CV metadata
  publishedAt DateTime @default(now()) // used for ordering and "date" display
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publishedAt(sort: Desc)])
  @@index([category])
  @@index([slug])
}

// --- Fleet & logistics vertical ---

enum FleetVehicleOwnership {
  managed
  outsourced
}

enum FleetVehicleStatus {
  available
  in_transit
  maintenance
  out_of_service
}

enum FleetDriverStatus {
  available
  on_trip
  off_duty
  suspended
}

enum FleetOrderStatus {
  draft
  validated
  assigned
  in_progress
  completed
  cancelled
}

enum FleetTripStatus {
  planned
  allocated
  compliance_check
  loaded
  in_transit
  delivered
  settled
  invoiced
  closed
  exception
}

model FleetVehicle {
  id                  String               @id @default(cuid())
  outsourcingClientId String
  registration        String
  label               String?
  vehicleType         String?
  capacityKg          Int?
  capacityCbm         Decimal?             @db.Decimal(10, 2)
  ownership           FleetVehicleOwnership @default(managed)
  status              FleetVehicleStatus   @default(available)
  depotLocation       String?
  odometerKm          Int?
  notes               String?              @db.Text
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  client OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  trips  FleetTrip[]

  @@unique([outsourcingClientId, registration])
  @@index([outsourcingClientId, status])
}

model FleetDriver {
  id                  String           @id @default(cuid())
  outsourcingClientId String
  employeeId          String?          @unique
  fullName            String
  phone               String?
  licenceNumber       String?
  licenceClass        String?
  licenceExpiry       DateTime?        @db.Date
  status              FleetDriverStatus @default(available)
  notes               String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  client   OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  employee Employee?         @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  trips    FleetTrip[]

  @@index([outsourcingClientId, status])
}

model FleetTransportPartner {
  id                  String   @id @default(cuid())
  outsourcingClientId String
  name                String
  contactName         String?
  contactPhone        String?
  contactEmail        String?
  payoutDetails       String?  @db.Text
  notes               String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  trips  FleetTrip[]

  @@index([outsourcingClientId, name])
}

model FleetCustomer {
  id                  String   @id @default(cuid())
  outsourcingClientId String
  name                String
  contactName         String?
  contactPhone        String?
  contactEmail        String?
  billingTerms        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  orders FleetOrder[]
  trips  FleetTrip[]

  @@index([outsourcingClientId, name])
}

model FleetOrder {
  id                  String           @id @default(cuid())
  outsourcingClientId String
  customerId          String
  orderNumber         String
  pickupLocation      String
  deliveryLocation    String
  cargoType           String?
  cargoWeightKg       Int?
  cargoVolumeCbm      Decimal?         @db.Decimal(10, 2)
  truckRequirements   String?
  requestedPickupAt   DateTime?
  status              FleetOrderStatus @default(draft)
  notes               String?          @db.Text
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  client   OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  customer FleetCustomer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  trips    FleetTrip[]

  @@unique([outsourcingClientId, orderNumber])
  @@index([outsourcingClientId, status])
}

model FleetTrip {
  id                  String          @id @default(cuid())
  outsourcingClientId String
  tripNumber          String
  orderId             String?
  customerId          String
  vehicleId           String?
  driverId            String?
  partnerId           String?
  status              FleetTripStatus @default(planned)
  origin              String
  destination         String
  cargoType           String?
  cargoWeightKg       Int?
  plannedDistanceKm   Int?
  actualDistanceKm    Int?
  plannedDeliveryAt   DateTime?
  actualDeliveryAt    DateTime?
  isOutsourced        Boolean         @default(false)
  notes               String?         @db.Text
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  client   OutsourcingClient      @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  order    FleetOrder?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer FleetCustomer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle  FleetVehicle?          @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver   FleetDriver?           @relation(fields: [driverId], references: [id], onDelete: SetNull)
  partner  FleetTransportPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  events           FleetTripEvent[]
  complianceChecks FleetTripComplianceCheck[]
  documents        FleetTripDocument[]
  settlement       FleetSettlement?
  incidents        FleetIncident[]
  clientInvoiceId  String?                  @unique
  clientInvoice    AccountsInvoice?           @relation("FleetTripClientInvoice", fields: [clientInvoiceId], references: [id], onDelete: SetNull)

  @@unique([outsourcingClientId, tripNumber])
  @@index([outsourcingClientId, status])
  @@index([vehicleId])
  @@index([driverId])
}

model FleetTripEvent {
  id        String   @id @default(cuid())
  tripId    String
  eventType String
  message   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  trip FleetTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt(sort: Desc)])
}

enum FleetComplianceCheckType {
  driver_licence
  vehicle_insurance
  vehicle_inspection
  cargo_documents
  transport_permit_local
  transport_permit_transit
}

enum FleetComplianceResult {
  pending
  passed
  failed
  waived
}

model FleetTripComplianceCheck {
  id              String                 @id @default(cuid())
  tripId          String
  checkType       FleetComplianceCheckType
  result          FleetComplianceResult  @default(pending)
  notes           String?                @db.Text
  evidenceUrl     String?
  checkedByUserId String?
  checkedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  trip      FleetTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  checkedBy User?     @relation("FleetComplianceCheckedBy", fields: [checkedByUserId], references: [id], onDelete: SetNull)

  @@unique([tripId, checkType])
  @@index([tripId])
}

enum FleetTripDocumentType {
  delivery_note
  transport_permit
  pod
  other
}

model FleetTripDocument {
  id               String                @id @default(cuid())
  tripId           String
  docType          FleetTripDocumentType
  title            String
  fileUrl          String
  fileName         String
  fileSize         Int?
  mimeType         String?
  uploadedByUserId String?
  createdAt        DateTime              @default(now())

  trip       FleetTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  uploadedBy User?     @relation("FleetTripDocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([tripId, createdAt(sort: Desc)])
}

enum FleetSettlementType {
  driver
  partner
}

enum FleetSettlementStatus {
  pending
  approved
  paid
}

model FleetSettlement {
  id                  String                @id @default(cuid())
  outsourcingClientId String
  tripId              String                @unique
  settlementType      FleetSettlementType
  payeeName           String
  amountKes           Decimal               @db.Decimal(14, 2)
  status              FleetSettlementStatus @default(pending)
  podVerified         Boolean               @default(false)
  notes               String?               @db.Text
  approvedAt          DateTime?
  paidAt              DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  client OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  trip   FleetTrip         @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([outsourcingClientId, status])
}

enum FleetIncidentType {
  breakdown
  accident
  delay
  dispute
}

enum FleetIncidentSeverity {
  low
  medium
  high
}

enum FleetIncidentStatus {
  open
  investigating
  resolved
  closed
}

model FleetIncident {
  id                  String                @id @default(cuid())
  outsourcingClientId String
  tripId              String
  incidentType        FleetIncidentType
  severity            FleetIncidentSeverity @default(medium)
  status              FleetIncidentStatus   @default(open)
  title               String
  description         String                @db.Text
  resolution          String?               @db.Text
  reportedAt          DateTime              @default(now())
  resolvedAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  client OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  trip   FleetTrip         @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([outsourcingClientId, status])
  @@index([tripId])
}

// --- Procurement (purchase requests) ---

enum PurchaseRequestStatus {
  draft
  submitted
  approved
  rejected
  cancelled
}

model PurchaseRequest {
  id                  String                @id @default(cuid())
  outsourcingClientId String
  requestNumber       String                @unique
  title               String
  department          String?
  justification       String                @db.Text
  currency            String                @default("KES")
  totalAmount         Decimal               @default(0) @db.Decimal(14, 2)
  status              PurchaseRequestStatus @default(draft)
  vendorId            String?
  requestedByUserId   String
  submittedAt         DateTime?
  reviewedAt          DateTime?
  reviewedByUserId    String?
  rejectionReason     String?               @db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  client      OutsourcingClient     @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  vendor      AccountsVendor?       @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  requestedBy User                  @relation("PurchaseRequestRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  reviewedBy  User?                 @relation("PurchaseRequestReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  lines       PurchaseRequestLine[]

  @@index([outsourcingClientId])
  @@index([status])
  @@index([requestedByUserId])
  @@index([submittedAt])
}

model PurchaseRequestLine {
  id          String   @id @default(cuid())
  requestId   String
  item        String
  description String?  @db.Text
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal  @db.Decimal(14, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  request PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}
