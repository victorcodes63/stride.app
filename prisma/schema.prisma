// HRIS Demo — scalable schema (recruitment, payroll, workforce)
// Use PostgreSQL in production (Vercel Postgres, Neon, Supabase, or self-hosted)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Legacy: optional link for Accounts (type=recruitment) and Job.clientId. Single-tenant recruitment
// uses RecruitmentSettings; do not add multiple "employer" clients for job posting.
model Client {
  id           String   @id @default(cuid())
  name         String
  isAnonymous  Boolean  @default(false) // legacy; prefer Job.concealCompany for confidential listings
  contactName  String?  // primary contact person name
  contactEmail String?  // primary contact email
  contactPhone String?  // primary contact phone
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs Job[]
  accountsClient AccountsClient?
  recruitmentPortalUsers RecruitmentClientPortalUser[]
  recruitmentSettingsLink RecruitmentSettings? @relation("RecruitmentLinkedClient")

  @@index([name])
}

/// Single row (id = "default"): the organization that owns careers / hiring.
model RecruitmentSettings {
  id             String   @id @default("default")
  employerName   String
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  /// Optional: one `Client` row for Accounts (recruitment) billing and legacy Job.clientId
  linkedClientId String?  @unique
  linkedClient   Client?  @relation("RecruitmentLinkedClient", fields: [linkedClientId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// View-only recruitment portal logins for employer contacts (separate from internal `User` / staff).
model RecruitmentClientPortalUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  clientId     String
  isActive     Boolean  @default(true)
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([isActive])
}

// Outsourcing clients – companies we provide HR outsourcing for (separate from recruitment clients)
model OutsourcingClient {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Tax & registration (Kenya)
  kraPin                 String?
  nssfEmployerNumber     String?
  nhifEmployerNumber     String?
  companyRegistrationNumber String?
  vatNumber              String?

  // Banking & billing
  bankName               String?
  bankAccountNumber      String?
  bankBranch             String?
  bankSwiftCode          String?
  currency               String?  @default("KES")
  billingCycle           String?  // monthly | bi_weekly | weekly
  serviceFeeType         String?  // fixed | percentage | per_employee
  serviceFeeAmount       Decimal? @db.Decimal(12, 2)
  paymentTerms           String?  // e.g. Net 15, Net 30, due on receipt

  /// Dashboard entity switcher: `ke` | `ug` — scopes workforce, payroll, and linked accounts when set.
  entityCode             String?  @unique

  // Address
  postalAddress          String?
  county                 String?

  // Contract
  contractStartDate      DateTime?
  contractEndDate        DateTime?

  // Employee IDs: auto {prefix}-001 per client; override prefix e.g. BW for "Blue Wave"
  employeeNumberPrefix   String?
  /// monthly = one payslip/stat run per month. biweekly = two period grosses; statutory on combined month gross, split for payslips.
  payrollFrequency       String?  @default("monthly")
  /// none | paye_only (NSSF/SHIF/AHL on employment gross only; PAYE on gross+leave; net + leave) | included_in_gross (leave in gross before all stat)
  leavePayMode           String?  @default("none")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  departments Department[]
  employees   Employee[]
  accountsClient AccountsClient?
  shiftTemplates ShiftTemplate[]
  rotaPeriods    RotaPeriod[]
  biometricDevices BiometricDevice[]
  statutoryReturns StatutoryReturn[]
  attendancePolicies AttendancePolicy[]
  leavePolicies      LeavePolicy[]
  attendanceEvents   AttendanceEvent[]
  attendanceDaySummaries AttendanceDaySummary[]
  employeeTransfersOut EmployeeEntityTransfer[] @relation("EmployeeEntityTransferSourceClient")
  employeeTransfersIn  EmployeeEntityTransfer[] @relation("EmployeeEntityTransferTargetClient")
  employeeLifecycleEvents EmployeeLifecycleEvent[]
  companyAssets           CompanyAsset[]
  fleetVehicles           FleetVehicle[]
  fleetDrivers            FleetDriver[]
  fleetTransportPartners  FleetTransportPartner[]
  fleetCustomers          FleetCustomer[]
  fleetOrders             FleetOrder[]
  fleetTrips              FleetTrip[]
  fleetSettlements        FleetSettlement[]
  fleetIncidents          FleetIncident[]
  purchaseRequests        PurchaseRequest[]

  @@index([name])
}

// --- Rota / shift scheduling (outsourcing employees) ---

/// Reusable shift pattern for an outsourcing client (e.g. Morning 06:00–14:00).
model ShiftTemplate {
  id                    String   @id @default(cuid())
  outsourcingClientId  String
  name                  String
  /// Minutes from midnight (0–1439). If endMinutes <= startMinutes, the shift crosses midnight.
  startMinutes         Int
  endMinutes           Int
  /// Unpaid break within the shift (excluded from weekly hours totals).
  breakMinutes         Int      @default(0)
  /// Optional color token for UI (e.g. hex).
  color                String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  client       OutsourcingClient  @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  assignments  ShiftAssignment[]

  @@index([outsourcingClientId, isActive])
}

/// A dated planning window (e.g. a week) for one outsourcing client.
model RotaPeriod {
  id                    String   @id @default(cuid())
  outsourcingClientId  String
  name                  String?
  startDate             DateTime  @db.Date
  endDate               DateTime  @db.Date
  status                RotaPeriodStatus @default(draft)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  client        OutsourcingClient  @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  assignments   ShiftAssignment[]

  @@index([outsourcingClientId, startDate])
  @@index([endDate])
}

enum RotaPeriodStatus {
  draft
  published
}

/// A concrete shift instance for an employee in a rota period.
model ShiftAssignment {
  id                 String   @id @default(cuid())
  rotaPeriodId       String
  employeeId         String
  shiftTemplateId   String?
  workDate          DateTime  @db.Date
  startsAt          DateTime
  endsAt            DateTime
  breakMinutes      Int       @default(0)
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rotaPeriod   RotaPeriod   @relation(fields: [rotaPeriodId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftTemplate ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id], onDelete: SetNull)
  attendanceEvents AttendanceEvent[]

  @@index([rotaPeriodId])
  @@index([employeeId, workDate])
  @@index([employeeId, startsAt])
}

// Departments within an outsourcing client
model Department {
  id                  String   @id @default(cuid())
  outsourcingClientId String
  name                String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client    OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([outsourcingClientId])
}

// Employees of outsourcing clients (tied to client and optionally department)
model Employee {
  id                  String    @id @default(cuid())
  outsourcingClientId String
  departmentId        String?
  managerEmployeeId   String?
  employeeNumber      String?   // internal EMP No. e.g. 001, 002
  firstName           String
  lastName            String
  /// Optional for casuals / hard-copy payslips; add when email delivery is needed.
  email               String?
  phone               String?
  idNumber            String?   // national ID
  kraPin              String?   // Kenya Revenue Authority PIN
  nssfNumber          String?   // National Social Security Fund
  nhifNumber          String?   // National Hospital Insurance Fund
  dateOfJoining       DateTime?
  jobTitle            String?
  costCenterCode      String?
  costCenterName      String?
  /// Monthly basic pay (KES). Pre-fills payroll when you generate a month; edit per month if needed.
  baseSalary          Decimal?  @db.Decimal(12, 2)
  // Bank details for salary disbursement
  bankName            String?
  bankBranch          String?
  bankAccountNumber   String?
  employmentStatus    EmployeeEmploymentStatus @default(active)
  employmentStatusEffectiveFrom DateTime?
  employmentStatusEffectiveTo DateTime?
  employmentEndedAt   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  client         OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  department     Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  manager        Employee?      @relation("EmployeeManager", fields: [managerEmployeeId], references: [id], onDelete: SetNull)
  subordinates   Employee[]     @relation("EmployeeManager")
  payrolls       Payroll[]
  leaveBalances  LeaveBalance[]
  leaveApplications LeaveApplication[]
  attendances    Attendance[]
  shiftAssignments ShiftAssignment[]
  biometricPunches BiometricPunch[]
  credentials    EmployeeCredential[]
  essPortalUsers EssPortalUser[]
  attendancePolicyAssignments AttendancePolicyAssignment[]
  leavePolicyAssignments LeavePolicyAssignment[]
  attendanceEvents AttendanceEvent[]
  attendanceSummaries AttendanceDaySummary[]
  attendanceExceptions AttendanceException[]
  leaveBalanceLedgers LeaveBalanceLedger[]
  documents      EmployeeDocument[]
  lifecycleEvents EmployeeLifecycleEvent[]
  onboardingWorkflows OnboardingWorkflow[]
  disciplinaryCases   DisciplinaryCase[]
  grievancesFiled     Grievance[]
  grievancesAgainst   Grievance[] @relation("GrievanceAgainst")
  entityTransfersOut  EmployeeEntityTransfer[] @relation("EmployeeEntityTransferSourceEmployee")
  entityTransfersIn   EmployeeEntityTransfer[] @relation("EmployeeEntityTransferTargetEmployee")
  assignedAssets      CompanyAsset[]
  fleetDriverProfile  FleetDriver?

  @@index([outsourcingClientId])
  @@index([departmentId])
  @@index([managerEmployeeId])
  @@index([employmentStatus])
  @@index([costCenterCode])
  @@index([email])
  /// One national ID maps to at most one employee record system-wide (multiple NULL allowed).
  @@unique([idNumber])
}

enum EmployeeLifecycleEventType {
  hire
  confirmation
  promotion
  transfer
  suspension
  separation
}

model EmployeeLifecycleEvent {
  id                   String                    @id @default(cuid())
  employeeId           String
  outsourcingClientId  String
  eventType            EmployeeLifecycleEventType
  effectiveDate        DateTime                  @db.Date
  reason               String?                   @db.Text
  notes                String?                   @db.Text
  fromJobTitle         String?
  toJobTitle           String?
  fromDepartmentId     String?
  toDepartmentId       String?
  fromEmploymentStatus EmployeeEmploymentStatus?
  toEmploymentStatus   EmployeeEmploymentStatus?
  actedByUserId        String?
  metadata             Json?
  createdAt            DateTime                  @default(now())

  employee   Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client     OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  actedByUser User?            @relation(fields: [actedByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId, effectiveDate(sort: Desc)])
  @@index([outsourcingClientId, eventType, effectiveDate(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model EmployeeEntityTransfer {
  id                    String   @id @default(cuid())
  employeeId            String
  sourceEmployeeId      String
  sourceClientId        String
  sourceEntityCode      String
  targetClientId        String
  targetEntityCode      String
  effectiveAt           DateTime
  transferReason        String?  @db.Text
  initiatedByUserId     String?
  previousDepartmentId  String?
  previousJobTitle      String?
  previousEmploymentStatus EmployeeEmploymentStatus?
  metadata              Json?
  createdAt             DateTime @default(now())

  sourceEmployee    Employee         @relation("EmployeeEntityTransferSourceEmployee", fields: [sourceEmployeeId], references: [id], onDelete: Cascade)
  targetEmployee    Employee         @relation("EmployeeEntityTransferTargetEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  sourceClient      OutsourcingClient @relation("EmployeeEntityTransferSourceClient", fields: [sourceClientId], references: [id], onDelete: Restrict)
  targetClient      OutsourcingClient @relation("EmployeeEntityTransferTargetClient", fields: [targetClientId], references: [id], onDelete: Restrict)
  initiatedByUser   User?            @relation(fields: [initiatedByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId, createdAt(sort: Desc)])
  @@index([sourceEntityCode, targetEntityCode, createdAt(sort: Desc)])
  @@index([sourceClientId])
  @@index([targetClientId])
}

model DisciplinaryCase {
  id           String  @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  caseNumber   String  @unique
  type         DisciplinaryCaseType
  status       DisciplinaryCaseStatus @default(OPEN)
  severity     DisciplinarySeverity   @default(MINOR)
  subject      String
  description  String   @db.Text
  incidentDate DateTime
  reportedDate DateTime @default(now())
  reportedById String
  reportedBy   User     @relation("CaseReporter", fields: [reportedById], references: [id])
  actions      DisciplinaryAction[]
  documents    DisciplinaryDocument[]
  resolution   String?  @db.Text
  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?    @relation("CaseResolver", fields: [resolvedById], references: [id])
  /// Primary labour-law frame for letters & SLA hints (KE, UG, TZ, RW, BI, SS, EAC).
  laborJurisdiction String @default("KE")
  /// Fair process: deadline for written response to show-cause (HR sets when letter issued).
  showCauseResponseDueAt DateTime?
  /// Scheduled disciplinary / appeal hearing.
  hearingAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([type])
}

model DisciplinaryAction {
  id                    String @id @default(cuid())
  caseId                 String
  disciplinaryCase       DisciplinaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type                   DisciplinaryActionType
  description            String   @db.Text
  actionDate             DateTime @default(now())
  performedById          String
  performedBy            User     @relation("DisciplinaryActionPerformer", fields: [performedById], references: [id])
  employeeResponse       String?  @db.Text
  employeeAcknowledged   Boolean  @default(false)
  acknowledgedAt         DateTime?
  nextActionDue          DateTime?
  letterGenerated        Boolean  @default(false)
  notes                  String?  @db.Text
  overrideSequence       Boolean  @default(false)
  overrideReason         String?  @db.Text

  @@index([caseId, actionDate])
}

model DisciplinaryDocument {
  id           String @id @default(cuid())
  caseId        String
  disciplinaryCase DisciplinaryCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title        String
  filePath     String
  fileName     String
  uploadedById String
  uploadedBy   User     @relation("DisciplinaryDocumentUploader", fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())

  @@index([caseId])
}

model Grievance {
  id                 String @id @default(cuid())
  employeeId         String
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  grievanceNumber    String @unique
  status             GrievanceStatus @default(SUBMITTED)
  subject            String
  description        String @db.Text
  category           GrievanceCategory
  againstId          String?
  against            Employee? @relation("GrievanceAgainst", fields: [againstId], references: [id])
  investigationNotes String? @db.Text
  resolution         String? @db.Text
  resolvedAt         DateTime?
  resolvedById       String?
  resolvedBy         User? @relation("GrievanceResolver", fields: [resolvedById], references: [id])
  submittedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}

enum DisciplinaryCaseType {
  MISCONDUCT
  POOR_PERFORMANCE
  POLICY_VIOLATION
  INSUBORDINATION
  ABSENTEEISM
  HARASSMENT
  NEGLIGENCE
  OTHER
}

enum DisciplinaryCaseStatus {
  OPEN
  UNDER_INVESTIGATION
  HEARING_SCHEDULED
  AWAITING_RESPONSE
  RESOLVED
  ESCALATED
  CLOSED
}

enum DisciplinarySeverity {
  MINOR
  MODERATE
  SERIOUS
  GROSS
}

enum DisciplinaryActionType {
  VERBAL_WARNING
  WRITTEN_WARNING
  FINAL_WARNING
  SHOW_CAUSE_LETTER
  HEARING
  SUSPENSION
  DEMOTION
  TERMINATION
  CASE_DISMISSED
}

enum GrievanceStatus {
  SUBMITTED
  UNDER_REVIEW
  INVESTIGATING
  RESOLVED
  ESCALATED
  WITHDRAWN
}

enum GrievanceCategory {
  WORKPLACE_SAFETY
  HARASSMENT
  DISCRIMINATION
  WORKLOAD
  MANAGEMENT
  COMPENSATION
  POLICY
  OTHER
}

enum EmployeeDocumentCategory {
  CONTRACT
  IDENTIFICATION
  QUALIFICATION
  PERFORMANCE
  DISCIPLINARY
  POLICY_ACKNOWLEDGMENT
  MEDICAL
  OTHER
}

model EmployeeDocument {
  id         String                   @id @default(cuid())
  employeeId String
  employee   Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  title      String
  category   EmployeeDocumentCategory
  filePath   String
  fileName   String
  fileSize   Int?
  mimeType   String?
  documentNumber String?
  issuedOn      DateTime?               @db.Date
  expiresOn     DateTime?               @db.Date
  isVerified    Boolean                 @default(false)
  tags          Json?

  notes      String?
  uploadedBy String
  uploader   User                     @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)
  uploadedAt DateTime                 @default(now())

  @@index([employeeId])
  @@index([category])
  @@index([expiresOn])
  @@index([isVerified])
}

enum EmployeeEmploymentStatus {
  active
  probation
  on_leave
  suspended
  terminated
}

enum WorkflowType {
  ONBOARDING
  OFFBOARDING
}

enum WorkflowStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OnboardingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  OVERDUE
}

model OnboardingTemplate {
  id        String   @id @default(cuid())
  name      String
  type      WorkflowType
  isDefault Boolean  @default(false)
  steps     OnboardingTemplateStep[]
  workflows OnboardingWorkflow[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OnboardingTemplateStep {
  id            String             @id @default(cuid())
  templateId    String
  template      OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  assignedRole  String
  order         Int
  dueDaysOffset Int      @default(3)
  isRequired    Boolean  @default(true)
  category      String?

  @@index([templateId, order])
}

model OnboardingWorkflow {
  id          String             @id @default(cuid())
  employeeId  String
  employee    Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  templateId  String
  template    OnboardingTemplate @relation(fields: [templateId], references: [id])
  type        WorkflowType
  status      WorkflowStatus     @default(IN_PROGRESS)
  startedAt   DateTime           @default(now())
  completedAt DateTime?
  tasks       OnboardingTask[]

  @@index([employeeId])
  @@index([status])
}

model OnboardingTask {
  id            String               @id @default(cuid())
  workflowId    String
  workflow      OnboardingWorkflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  assignedRole  String
  assignedToId  String?
  assignedTo    User?                @relation("OnboardingTaskAssignee", fields: [assignedToId], references: [id])
  category      String?
  order         Int
  isRequired    Boolean              @default(true)
  dueDate       DateTime?
  status        OnboardingTaskStatus @default(PENDING)
  completedAt   DateTime?
  completedById String?
  completedBy   User?                @relation("OnboardingTaskCompletedBy", fields: [completedById], references: [id])
  notes         String?
  documentId    String?

  @@index([workflowId, order])
  @@index([assignedRole, status])
  @@index([assignedToId, status])
}

enum AttendancePolicyMode {
  biometric_primary
  hybrid_override
  manual_primary
}

model AttendancePolicy {
  id                    String   @id @default(cuid())
  outsourcingClientId   String
  name                  String
  description           String?  @db.Text
  mode                  AttendancePolicyMode @default(hybrid_override)
  graceInMinutes        Int      @default(0)
  graceOutMinutes       Int      @default(0)
  minHalfDayMinutes     Int      @default(240)
  fullDayMinutes        Int      @default(480)
  requireManualApproval Boolean  @default(true)
  isDefault             Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  client       OutsourcingClient            @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  assignments  AttendancePolicyAssignment[]
  dailySummaries AttendanceDaySummary[]

  @@index([outsourcingClientId, isActive])
  @@index([outsourcingClientId, isDefault])
}

model AttendancePolicyAssignment {
  id                 String   @id @default(cuid())
  employeeId         String
  attendancePolicyId String
  effectiveFrom      DateTime @db.Date
  effectiveTo        DateTime? @db.Date
  isPrimary          Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendancePolicy AttendancePolicy @relation(fields: [attendancePolicyId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveFrom])
  @@index([attendancePolicyId, effectiveFrom])
}

enum LeaveAccrualMode {
  annual_grant
  monthly_accrual
}

model LeavePolicy {
  id                  String   @id @default(cuid())
  outsourcingClientId String
  name                String
  description         String?  @db.Text
  isDefault           Boolean  @default(false)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client      OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  rules       LeavePolicyRule[]
  assignments LeavePolicyAssignment[]

  @@index([outsourcingClientId, isDefault])
  @@index([outsourcingClientId, isActive])
}

model LeavePolicyRule {
  id                  String   @id @default(cuid())
  leavePolicyId       String
  leaveTypeId         String
  accrualMode         LeaveAccrualMode @default(monthly_accrual)
  annualEntitlement   Int      @default(0)
  monthlyAccrualDays  Decimal  @default(0) @db.Decimal(6, 2)
  maxCarryForwardDays Int      @default(0)
  requiresApproval    Boolean  @default(true)
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  leavePolicy LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)
  leaveType   LeaveType   @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([leavePolicyId, leaveTypeId])
  @@index([leaveTypeId])
}

model LeavePolicyAssignment {
  id            String   @id @default(cuid())
  employeeId    String
  leavePolicyId String
  effectiveFrom DateTime @db.Date
  effectiveTo   DateTime? @db.Date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leavePolicy LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)

  @@index([employeeId, effectiveFrom])
  @@index([leavePolicyId, effectiveFrom])
}

enum AttendanceEventSource {
  biometric
  manual
  rota
}

enum AttendanceEventKind {
  check_in
  check_out
  break_start
  break_end
  override
}

model AttendanceEvent {
  id                 String   @id @default(cuid())
  employeeId         String
  outsourcingClientId String
  observedAt         DateTime
  workDate           DateTime @db.Date
  source             AttendanceEventSource
  kind               AttendanceEventKind
  biometricPunchId   String?
  shiftAssignmentId  String?
  createdByUserId    String?
  isApprovedOverride Boolean  @default(false)
  notes              String?  @db.Text
  metadata           Json?
  createdAt          DateTime @default(now())

  employee       Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client         OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  biometricPunch BiometricPunch?   @relation(fields: [biometricPunchId], references: [id], onDelete: SetNull)
  shiftAssignment ShiftAssignment? @relation(fields: [shiftAssignmentId], references: [id], onDelete: SetNull)
  createdByUser  User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId, workDate])
  @@index([outsourcingClientId, workDate])
  @@index([source, workDate])
}

enum AttendanceSummaryStatus {
  draft
  reconciled
  approved
}

model AttendanceDaySummary {
  id                 String   @id @default(cuid())
  employeeId         String
  outsourcingClientId String
  workDate           DateTime @db.Date
  attendancePolicyId String?
  firstInAt          DateTime?
  lastOutAt          DateTime?
  minutesWorked      Int      @default(0)
  lateMinutes        Int      @default(0)
  undertimeMinutes   Int      @default(0)
  overtimeMinutes    Int      @default(0)
  holidayOvertimeMinutes Int  @default(0)
  publicHolidayName  String?
  status             AttendanceSummaryStatus @default(draft)
  sourceBreakdown    Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  client   OutsourcingClient @relation(fields: [outsourcingClientId], references: [id], onDelete: Cascade)
  attendancePolicy AttendancePolicy? @relation(fields: [attendancePolicyId], references: [id], onDelete: SetNull)
  exceptions AttendanceException[]

  @@unique([employeeId, workDate])
  @@index([outsourcingClientId, workDate])
  @@index([status])
}

model PublicHoliday {
