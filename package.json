{
  "name": "hris-demo",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "npx tsx prisma/seed-all-demo.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --turbopack",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "dev:stable": "next dev",
    "build": "node scripts/prisma-migrate-deploy.js && next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "set -a; [ -f .env.local ] && . ./.env.local; set +a; prisma generate",
    "db:push": "set -a; [ -f .env.local ] && . ./.env.local; set +a; prisma db push",
    "db:migrate": "set -a; [ -f .env.local ] && . ./.env.local; set +a; prisma migrate dev",
    "db:migrate:deploy": "set -a; [ -f .env.local ] && . ./.env.local; set +a; prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset-for-go-live": "node prisma/reset-for-go-live.js",
    "db:reset-ess-shell": "set -a; [ -f .env.local ] && . ./.env.local; set +a; npx tsx prisma/reset-ess-shell.ts",
    "db:reset-empty": "set -a; [ -f .env.local ] && . ./.env.local; set +a; npx tsx prisma/reset-ess-shell.ts -- --purge-ess",
    "db:seed-candidates": "node prisma/seed-candidates.js",
    "db:seed-full-dev": "node prisma/seed-full-dev.js",
    "db:seed-staff": "node prisma/seed-staff.js",
    "db:seed-invite-recipients": "node prisma/seed-two-invite-recipients.js",
    "db:seed-insights": "node prisma/seed-insights.js",
    "db:seed-outsourcing-clients": "node prisma/seed-outsourcing-clients.js",
    "db:seed-outsourcing-employees": "node prisma/seed-outsourcing-employees.js",
    "db:seed-stabex-demo": "node prisma/seed-stabex-demo.js",
    "db:cleanup-legacy-branding": "node prisma/cleanup-legacy-staff-branding.js",
    "db:cleanup-staff-emails": "node prisma/cleanup-staff-legacy-emails.js",
    "db:purge-stabex": "set -a; [ -f .env.local ] && . ./.env.local; set +a; npx tsx prisma/purge-stabex-leakage.ts",
    "db:clear-outsourcing": "node prisma/clear-outsourcing.js",
    "db:seed-one-outsourcing": "node prisma/seed-one-outsourcing-client.js",
    "db:seed-sabic-payroll": "node prisma/seed-sabic-payroll-employees.js",
    "db:set-payroll-test-user": "node prisma/set-payroll-test-employee.js",
    "db:seed-staff-leave": "node prisma/seed-staff-leave.js",
    "db:seed-biweekly-client": "node prisma/seed-biweekly-client.js",
    "db:seed-biometric-hikvision": "node prisma/seed-biometric-hikvision.js",
    "db:seed-onboarding-templates": "npx tsx prisma/seed-onboarding-templates.ts",
    "seed:demo": "npx tsx prisma/seed-demo.ts",
    "seed:demo:generic": "DEMO_PACK=generic npx tsx prisma/seed-demo.ts",
    "seed:demo:petroleum-retail": "DEMO_PACK=petroleum-retail npx tsx prisma/seed-demo.ts",
    "demo:context": "node scripts/apply-demo-context.mjs",
    "demo:reseed": "node scripts/apply-demo-context.mjs generic --reseed",
    "demo:reseed:generic": "node scripts/apply-demo-context.mjs generic --reseed",
    "demo:reseed:petroleum-retail": "node scripts/apply-demo-context.mjs petroleum-retail --reseed",
    "demo:reseed:imara-sacco": "node scripts/apply-demo-context.mjs imara-sacco --reseed",
    "seed:demo:imara-sacco": "DEMO_PACK=imara-sacco npx tsx prisma/seed-demo.ts",
    "demo:reseed:all-contexts": "set -a; [ -f .env.local ] && . ./.env.local; set +a; DEMO_MULTI_CONTEXT=true npx tsx prisma/seed-demo-multi-context.ts",
    "demo:reseed:all-verticals": "set -a; [ -f .env.local ] && . ./.env.local; set +a; DEMO_MULTI_CONTEXT=true DEMO_UNIFIED_ADMIN_EMAIL=demo@demo.imara.co.ke npx tsx prisma/seed-demo-multi-vertical.ts",
    "demo:seed:training": "set -a; [ -f .env.local ] && . ./.env.local; set +a; npx tsx prisma/seed-training-demo.ts",
    "demo:context:all-verticals": "node scripts/apply-demo-context.mjs all-verticals",
    "seed:production": "npx tsx prisma/seed-production.ts",
    "db:seed-all-demo": "set -a; [ -f .env.local ] && . ./.env.local; set +a; npx tsx prisma/seed-all-demo.ts",
    "db:reset-demo": "set -a; [ -f .env.local ] && . ./.env.local; set +a; prisma migrate reset --force",
    "db:seed-disciplinary": "node prisma/seed-disciplinary-grievance.js",
    "db:seed-accounts": "node prisma/seed-accounts-module.js",
    "db:sync-accounts-clients": "node prisma/run-sync-accounts-clients.js",
    "db:seed-sample-invoice": "node prisma/seed-sample-invoice.js",
    "db:update-resume-paths": "node prisma/update-resume-paths.js",
    "env:check": "node scripts/env-check.mjs",
    "provision:check": "node scripts/provision-check.mjs",
    "provision:check:demo": "node scripts/provision-check.mjs --profile demo",
    "smoke:test": "node scripts/smoke-test.mjs",
    "smoke:platform": "node scripts/smoke-platform.mjs",
    "test:accounts-smtp": "node scripts/test-accounts-smtp.mjs",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^5.22.0",
    "@tabler/icons-react": "^3.40.0",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@types/nodemailer": "^7.0.2",
    "@vercel/blob": "^2.2.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.24",
    "geist": "^1.7.2",
    "isomorphic-dompurify": "^3.1.0",
    "lucide-react": "^0.545.0",
    "next": "15.5.9",
    "next-seo": "^6.8.0",
    "nodemailer": "^7.0.10",
    "pdf-lib": "^1.17.1",
    "prisma": "^5.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.65.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
