# Multi-vertical sales demo — all sectors seeded once, switch via top-bar dropdown
# Apply env: npm run demo:context -- all-verticals
# Seed all sectors: npm run demo:reseed:all-verticals

DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true
DEMO_MULTI_CONTEXT=true
MULTI_ENTITY_ENABLED=true

NEXT_PUBLIC_APP_NAME="Stride"
NEXT_PUBLIC_APP_TAGLINE="The Vertical BMS — explore payroll and people ops across industries."
NEXT_PUBLIC_BRAND_WORDMARK="Stride"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# One login works for every sector in the switcher
DEMO_UNIFIED_ADMIN_EMAIL="demo@demo.imara.co.ke"
STAFF_ALLOWED_DOMAIN="imara.co.ke,nyati.imara.co.ke,horizon.imara.co.ke,amani.imara.co.ke,swiftfreight.imara.co.ke,example.com,eaglehr.co.ke"
NEXT_PUBLIC_DEMO_ADMIN_EMAIL="demo@demo.imara.co.ke"
NEXT_PUBLIC_DEMO_PASSWORD="Demo@2026!"
STAFF_PASSWORD="Demo@2026!"

# Full platform visible in sales demo — all modules licensed (DEMO_MODE also forces license on)
# Opt out per module only for wedge-specific client deploys: MODULE_ATS=false etc.
