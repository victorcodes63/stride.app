# Imara — SACCO beachhead demo (Phase 1 wedge: People + Time + Payroll)
# Apply: npm run demo:reseed:imara-sacco

DEMO_PACK=imara-sacco
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Product identity (Imara Vertical BMS)
NEXT_PUBLIC_APP_NAME="Stride"
NEXT_PUBLIC_ORG_NAME="Nyati SACCO Society Ltd"
NEXT_PUBLIC_APP_TAGLINE="Hit your stride. HR, finance, and operations on one platform — built for East African businesses."
NEXT_PUBLIC_BRAND_LOGO="/brand/stride-mark.png"
NEXT_PUBLIC_BRAND_LOGO_PNG="/brand/stride-mark.png"
NEXT_PUBLIC_BRAND_WORDMARK="Stride"
NEXT_PUBLIC_RECRUITMENT_EMPLOYER_NAME="Nyati SACCO Society Ltd"
NEXT_PUBLIC_SITE_URL="https://hcm.raventechgroup.com"

# Demo login (matches imara-sacco pack seed)
STAFF_ALLOWED_DOMAIN="nyati.imara.co.ke,imara.co.ke,example.com,swiftfreight.imara.co.ke,amani.imara.co.ke,horizon.imara.co.ke"
NEXT_PUBLIC_DEMO_ADMIN_EMAIL="admin@imara.co.ke"
NEXT_PUBLIC_DEMO_HR_EMAIL="hr@nyati.imara.co.ke"
NEXT_PUBLIC_DEMO_APPROVER_EMAIL="hr@nyati.imara.co.ke"
NEXT_PUBLIC_DEMO_STAFF_EMAIL="james.otieno@eaglehr.co.ke"
NEXT_PUBLIC_DEMO_FINANCE_EMAIL="finance@nyati.imara.co.ke"
NEXT_PUBLIC_DEMO_ESS_EMAIL="employee@nyati.imara.co.ke"
NEXT_PUBLIC_DEMO_PASSWORD="Demo@2026!"
STAFF_PASSWORD="Demo@2026!"

# Unified admin across all verticals (multi-context switcher)
DEMO_UNIFIED_ADMIN_EMAIL="admin@imara.co.ke"

# Sales demo: full platform (People, Payroll, Talent, Finance, HSE, Assets, …)
